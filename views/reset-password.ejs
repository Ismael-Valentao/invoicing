<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Invoicing - Reset Password</title>
    <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png" />

    <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
        rel="stylesheet">
    <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet" />

    <style>
        body.bg-gradient-primary {
            background: linear-gradient(135deg, #0b4bff, #6a5cff) !important;
            min-height: 100vh;
        }

        .wrap {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 28px 0;
        }

        .cardx {
            border-radius: 18px;
            background: #fff;
            box-shadow: 0 22px 70px rgba(16, 24, 40, .20);
            overflow: hidden;
            border: 1px solid #e5e7eb;
        }

        .head {
            padding: 18px 22px;
            border-bottom: 1px solid #eef0f4;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .head img {
            width: 34px;
            height: 34px;
            border-radius: 10px;
        }

        .head .t1 {
            font-weight: 900;
            color: #111827;
            line-height: 1.1;
        }

        .head .t2 {
            font-size: .85rem;
            color: #6b7280;
        }

        .body {
            padding: 22px;
        }

        .iwrap {
            position: relative;
        }

        .iwrap i {
            position: absolute;
            top: 50%;
            left: 14px;
            transform: translateY(-50%);
            color: #9ca3af;
        }

        input.form-control {
            border-radius: 14px !important;
            padding: 1.05rem .95rem !important;
            border: 1px solid #e5e7eb !important;
            font-size: 0.9rem !important;
        }

        .iwrap input {
            padding-left: 44px !important;
        }

        .btnx {
            border-radius: 14px !important;
            padding: .70rem 1.1rem !important;
            font-weight: 800;
            box-shadow: 0 12px 30px rgba(37, 99, 235, .22);
        }
    </style>
</head>

<body class="bg-gradient-primary">
    <div class="wrap">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">
                    <div class="cardx">
                        <div class="head">
                            <img src="/images/invoicing-logo-simple.png" alt="logo">
                            <div>
                                <div class="t1">Nova palavra-passe</div>
                                <div class="t2">Defina uma palavra-passe segura</div>
                            </div>
                        </div>

                        <div class="body">
                            <div id="errorBox" class="alert alert-danger d-none text-center" role="alert"></div>

                            <form id="resetForm">
                                <div class="form-group">
                                    <label class="font-weight-bold">Palavra-passe</label>
                                    <div class="iwrap">
                                        <i class="fas fa-lock"></i>
                                        <input type="password" class="form-control" id="password"
                                            placeholder="••••••••••••" required>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label class="font-weight-bold">Repetir palavra-passe</label>
                                    <div class="iwrap">
                                        <i class="fas fa-lock"></i>
                                        <input type="password" class="form-control" id="password2"
                                            placeholder="••••••••••••" required>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary btnx btn-block" id="btnReset">
                                    Atualizar palavra-passe <i class="fas fa-check ml-2"></i>
                                </button>

                                <div class="text-center mt-3">
                                    <a class="small font-weight-bold" href="/login">Voltar ao login</a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="text-center mt-3" style="color:rgba(255,255,255,.85);font-size:.9rem;">
                        Invoicing © <%= new Date().getFullYear() %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const token = "<%= token %>";
            const form = document.getElementById("resetForm");
            const errorBox = document.getElementById("errorBox");
            const btn = document.getElementById("btnReset");

            function showError(msg) {
                errorBox.textContent = msg;
                errorBox.classList.remove("d-none");
            }

            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                errorBox.classList.add("d-none");

                const p1 = document.getElementById("password").value;
                const p2 = document.getElementById("password2").value;
                if (p1 !== p2) return showError("As palavras-passe não coincidem.");

                btn.disabled = true;
                btn.innerHTML = 'Atualizando... <i class="fas fa-spinner fa-spin ml-2"></i>';

                try {
                    const resp = await fetch(`/api/users/passwords/reset-password/${token}`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ password: p1 })
                    });

                    const data = await resp.json().catch(() => ({}));
                    if (!resp.ok) {
                        btn.disabled = false;
                        btn.innerHTML = 'Atualizar palavra-passe <i class="fas fa-check ml-2"></i>';
                        return showError(data.message || "Não foi possível redefinir. Link inválido ou expirado.");
                    }

                    window.location.href = "/login?reset=true";
                } catch (err) {
                    btn.disabled = false;
                    btn.innerHTML = 'Atualizar palavra-passe <i class="fas fa-check ml-2"></i>';
                    showError("Falha de conexão. Tente novamente.");
                }
            });
        })();
    </script>
</body>

</html>