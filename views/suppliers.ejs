<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>
  <title>Invoicing - <%- title %></title>
  <link rel="icon" type="image/png" href="images/invoicing-logo-simple.png"/>
  <link href="assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,400,600,700,800" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous"/>
  <link href="assets/css/sb-admin-2.min.css" rel="stylesheet"/>
  <link href="assets/css/custom.css" rel="stylesheet"/>
</head>
<body id="page-top">
<div id="wrapper">
  <%- include('partials/sidebar') %>
  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      <%- include('partials/topbar') %>
      <div class="container-fluid">
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
          <h5 class="mb-0 text-gray-800"><strong>Fornecedores</strong></h5>
          <button class="btn btn-primary btn-sm" data-toggle="modal" data-target="#newSupplierModal">
            <i class="fas fa-plus mr-1"></i>Novo Fornecedor
          </button>
        </div>

        <div class="card shadow mb-4">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="thead-light">
                  <tr><th>Nome</th><th>Email</th><th>Telefone</th><th>NUIT</th><th></th></tr>
                </thead>
                <tbody id="suppliersTbody">
                  <tr><td colspan="5" class="text-center text-muted py-3">A carregar...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    <%- include('partials/copyright') %>
  </div>
</div>

<!-- New Supplier Modal -->
<div class="modal fade" id="newSupplierModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-truck mr-2 text-primary"></i>Novo Fornecedor</h5>
        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <div class="form-group"><label class="small font-weight-bold">Nome *</label>
          <input type="text" class="form-control form-control-sm" id="supName"/></div>
        <div class="row">
          <div class="col-6"><div class="form-group"><label class="small font-weight-bold">Email</label>
            <input type="email" class="form-control form-control-sm" id="supEmail"/></div></div>
          <div class="col-6"><div class="form-group"><label class="small font-weight-bold">Telefone</label>
            <input type="text" class="form-control form-control-sm" id="supPhone"/></div></div>
        </div>
        <div class="row">
          <div class="col-6"><div class="form-group"><label class="small font-weight-bold">NUIT</label>
            <input type="text" class="form-control form-control-sm" id="supNuit"/></div></div>
          <div class="col-6"><div class="form-group"><label class="small font-weight-bold">Morada</label>
            <input type="text" class="form-control form-control-sm" id="supAddress"/></div></div>
        </div>
        <div class="form-group"><label class="small font-weight-bold">Notas</label>
          <textarea class="form-control form-control-sm" id="supNotes" rows="2"></textarea></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary btn-sm" onclick="saveSupplier()">
          <i class="fas fa-save mr-1"></i>Guardar
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
async function loadSuppliers() {
  const res = await fetch('/api/suppliers');
  const data = await res.json();
  const tbody = document.getElementById('suppliersTbody');
  if (!data.success || !data.suppliers.length) {
    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">Sem fornecedores.</td></tr>';
    return;
  }
  tbody.innerHTML = data.suppliers.map(s =>
    '<tr><td class="font-weight-bold">' + s.name + '</td>'
    + '<td class="small">' + (s.email||'—') + '</td>'
    + '<td class="small">' + (s.phone||'—') + '</td>'
    + '<td class="small">' + (s.nuit||'N/A') + '</td>'
    + '<td><button class="btn btn-outline-danger btn-sm" onclick="delSupplier(\'' + s._id + '\')"><i class="fas fa-trash"></i></button></td></tr>'
  ).join('');
}

async function saveSupplier() {
  const body = {
    name: document.getElementById('supName').value,
    email: document.getElementById('supEmail').value,
    phone: document.getElementById('supPhone').value,
    nuit: document.getElementById('supNuit').value,
    address: document.getElementById('supAddress').value,
    notes: document.getElementById('supNotes').value,
  };
  if (!body.name) return alert('Nome é obrigatório.');
  const res = await fetch('/api/suppliers', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
  const data = await res.json();
  if (data.success) { $('#newSupplierModal').modal('hide'); loadSuppliers(); }
  else alert(data.message);
}

async function delSupplier(id) {
  if (!confirm('Eliminar este fornecedor?')) return;
  await fetch('/api/suppliers/' + id, { method:'DELETE' });
  loadSuppliers();
}

loadSuppliers();
</script>
</body>
</html>
