<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>
  <title>Invoicing - <%- title %></title>
  <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png"/>
  <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,400,600,700,800" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous"/>
  <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet"/>
  <link href="/assets/css/custom.css" rel="stylesheet"/>
</head>
<body id="page-top">
<div id="wrapper">
  <%- include('partials/sidebar') %>
  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      <%- include('partials/topbar') %>
      <div class="container-fluid">
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
          <h5 class="mb-0 text-gray-800"><strong>Despesas</strong></h5>
          <button class="btn btn-primary btn-sm" data-toggle="modal" data-target="#newExpenseModal">
            <i class="fas fa-plus mr-1"></i>Nova Despesa
          </button>
        </div>

        <!-- Summary cards -->
        <div class="row mb-4">
          <div class="col-xl-4 col-md-6 mb-3">
            <div class="card border-left-danger shadow h-100 py-2">
              <div class="card-body">
                <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Total este mês</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800" id="expTotalMonth">—</div>
              </div>
            </div>
          </div>
          <div class="col-xl-8 col-md-6 mb-3">
            <div class="card shadow h-100 py-2">
              <div class="card-body">
                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Por categoria (este mês)</div>
                <div id="expByCategory" class="d-flex flex-wrap gap-2 mt-1" style="gap:8px;"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Filters -->
        <div class="card shadow mb-4">
          <div class="card-header py-2 d-flex align-items-center justify-content-between flex-wrap" style="gap:8px;">
            <h6 class="m-0 font-weight-bold text-primary">Lista de Despesas</h6>
            <div class="d-flex" style="gap:8px;">
              <select id="filterCategory" class="form-control form-control-sm" style="width:auto;">
                <option value="">Todas categorias</option>
                <option value="renda">Renda</option>
                <option value="salarios">Salários</option>
                <option value="fornecedores">Fornecedores</option>
                <option value="transporte">Transporte</option>
                <option value="comunicacao">Comunicação</option>
                <option value="material">Material</option>
                <option value="impostos">Impostos</option>
                <option value="manutencao">Manutenção</option>
                <option value="marketing">Marketing</option>
                <option value="outros">Outros</option>
              </select>
              <input type="date" id="filterFrom" class="form-control form-control-sm" style="width:auto;"/>
              <input type="date" id="filterTo" class="form-control form-control-sm" style="width:auto;"/>
              <button class="btn btn-sm btn-outline-primary" onclick="loadExpenses()"><i class="fas fa-filter"></i></button>
            </div>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="thead-light">
                  <tr>
                    <th>Data</th>
                    <th>Descrição</th>
                    <th>Categoria</th>
                    <th>Valor</th>
                    <th>Pagamento</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody id="expensesTbody">
                  <tr><td colspan="6" class="text-center text-muted py-3">A carregar...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    <%- include('partials/copyright') %>
  </div>
</div>

<!-- New Expense Modal -->
<div class="modal fade" id="newExpenseModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-wallet mr-2 text-danger"></i>Nova Despesa</h5>
        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label class="small font-weight-bold">Descrição *</label>
          <input type="text" class="form-control form-control-sm" id="expDesc" placeholder="Ex: Renda do mês"/>
        </div>
        <div class="row">
          <div class="col-6">
            <div class="form-group">
              <label class="small font-weight-bold">Valor (MZN) *</label>
              <input type="number" class="form-control form-control-sm" id="expAmount" step="0.01" min="0"/>
            </div>
          </div>
          <div class="col-6">
            <div class="form-group">
              <label class="small font-weight-bold">Data</label>
              <input type="date" class="form-control form-control-sm" id="expDate"/>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-6">
            <div class="form-group">
              <label class="small font-weight-bold">Categoria</label>
              <select class="form-control form-control-sm" id="expCategory">
                <option value="outros">Outros</option>
                <option value="renda">Renda</option>
                <option value="salarios">Salários</option>
                <option value="fornecedores">Fornecedores</option>
                <option value="transporte">Transporte</option>
                <option value="comunicacao">Comunicação</option>
                <option value="material">Material de escritório</option>
                <option value="impostos">Impostos</option>
                <option value="manutencao">Manutenção</option>
                <option value="marketing">Marketing</option>
              </select>
            </div>
          </div>
          <div class="col-6">
            <div class="form-group">
              <label class="small font-weight-bold">Pagamento</label>
              <select class="form-control form-control-sm" id="expPayment">
                <option value="cash">Dinheiro</option>
                <option value="emola">E-mola</option>
                <option value="bank">Transferência</option>
                <option value="card">Cartão</option>
              </select>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label class="small font-weight-bold">Referência</label>
          <input type="text" class="form-control form-control-sm" id="expRef" placeholder="Nº da transacção, etc."/>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary btn-sm" onclick="saveExpense()">
          <i class="fas fa-save mr-1"></i>Guardar
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
const currency = v => new Intl.NumberFormat('pt-MZ',{style:'currency',currency:'MZN'}).format(v||0);
const catLabels = {renda:'Renda',salarios:'Salários',fornecedores:'Fornecedores',transporte:'Transporte',comunicacao:'Comunicação',material:'Material',impostos:'Impostos',manutencao:'Manutenção',marketing:'Marketing',outros:'Outros'};
const payLabels = {cash:'Dinheiro',mpesa:'M-Pesa',emola:'E-mola',bank:'Transf.',card:'Cartão'};
const catColors = {renda:'#e74a3b',salarios:'#4e73df',fornecedores:'#1cc88a',transporte:'#f6c23e',comunicacao:'#36b9cc',material:'#858796',impostos:'#e74a3b',manutencao:'#fd7e14',marketing:'#6f42c1',outros:'#858796'};

async function loadSummary() {
  const res = await fetch('/api/expenses/summary');
  const data = await res.json();
  if (!data.success) return;
  document.getElementById('expTotalMonth').textContent = currency(data.summary.totalThisMonth);
  const catEl = document.getElementById('expByCategory');
  catEl.innerHTML = data.summary.byCategory.map(c =>
    '<span class="badge px-2 py-1" style="background:' + (catColors[c.category]||'#858796') + ';color:#fff;font-size:.8rem;">' + c.label + ': ' + currency(c.total) + '</span>'
  ).join('') || '<span class="text-muted small">Sem despesas este mês</span>';
}

async function loadExpenses() {
  const cat = document.getElementById('filterCategory').value;
  const from = document.getElementById('filterFrom').value;
  const to = document.getElementById('filterTo').value;
  let url = '/api/expenses?';
  if (cat) url += 'category=' + cat + '&';
  if (from) url += 'from=' + from + '&';
  if (to) url += 'to=' + to;
  const res = await fetch(url);
  const data = await res.json();
  const tbody = document.getElementById('expensesTbody');
  if (!data.success || !data.expenses.length) {
    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Sem despesas.</td></tr>';
    return;
  }
  tbody.innerHTML = data.expenses.map(e =>
    '<tr><td class="small">' + new Date(e.date).toLocaleDateString('pt-PT') + '</td>'
    + '<td>' + e.description + '</td>'
    + '<td><span class="badge" style="background:' + (catColors[e.category]||'#858796') + ';color:#fff;">' + (catLabels[e.category]||e.category) + '</span></td>'
    + '<td class="font-weight-bold">' + currency(e.amount) + '</td>'
    + '<td class="small">' + (payLabels[e.paymentMethod]||e.paymentMethod) + '</td>'
    + '<td><button class="btn btn-outline-danger btn-sm" onclick="delExpense(\'' + e._id + '\')"><i class="fas fa-trash"></i></button></td></tr>'
  ).join('');
}

async function saveExpense() {
  const body = {
    description: document.getElementById('expDesc').value,
    amount: parseFloat(document.getElementById('expAmount').value),
    date: document.getElementById('expDate').value || undefined,
    category: document.getElementById('expCategory').value,
    paymentMethod: document.getElementById('expPayment').value,
    reference: document.getElementById('expRef').value,
  };
  if (!body.description || !body.amount) return alert('Preencha descrição e valor.');
  const res = await fetch('/api/expenses', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
  const data = await res.json();
  if (data.success) {
    $('#newExpenseModal').modal('hide');
    document.getElementById('expDesc').value = '';
    document.getElementById('expAmount').value = '';
    loadExpenses(); loadSummary();
  } else { alert(data.message); }
}

async function delExpense(id) {
  if (!confirm('Eliminar esta despesa?')) return;
  await fetch('/api/expenses/' + id, { method:'DELETE' });
  loadExpenses(); loadSummary();
}

loadSummary(); loadExpenses();
</script>
</body>
</html>
