<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <title>Invoicing - <%- title %></title>
  <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png" />
  <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    crossorigin="anonymous" />
  <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet" />
  <link href="/assets/css/custom.css" rel="stylesheet" />
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('partials/sidebar') %>

      <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
          <%- include('partials/topbar') %>

            <div class="container-fluid">
              <!-- Banner de subscrição expirada -->
              <div id="subExpiredBanner" class="alert alert-danger align-items-center justify-content-between mb-3"
                style="display:none;">
                <span><i class="fas fa-lock mr-2"></i><strong>Subscrição expirada.</strong> Renova o teu plano para
                  continuar a criar vendas.</span>
                <a href="/upgrade" class="btn btn-danger btn-sm ml-3">Renovar agora</a>
              </div>

              <div id="subWarningBanner" class="alert alert-warning align-items-center justify-content-between mb-3"
                style="display:none;">
                <span><i class="fas fa-exclamation-triangle mr-2"></i>A tua subscrição expira em <strong
                    id="subDaysLeft"></strong> dias.</span>
                <a href="/upgrade" class="btn btn-warning btn-sm ml-3">Renovar</a>
              </div>
              <%- include('partials/onboarding-checklist') %>
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                  <h5 class="mb-0 text-gray-800"><strong>Dashboard de Vendas</strong></h5>

                  <div class="d-flex" style="gap:8px;">
                    <select id="range" class="form-control form-control-sm">
                      <option value="7" selected>Últimos 7 dias</option>
                      <option value="14">Últimos 14 dias</option>
                      <option value="30">Últimos 30 dias</option>
                    </select>
                    <button id="btn-refresh" class="btn btn-primary btn-sm">
                      <i class="fa-solid fa-rotate"></i>
                    </button>
                  </div>
                </div>

                <!-- Sales Goal -->
                <div class="card shadow mb-4" id="salesGoalCard" style="display:none;">
                  <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <h6 class="font-weight-bold text-primary mb-0"><i class="fas fa-bullseye mr-1"></i>Meta do mês</h6>
                      <div>
                        <span class="small text-muted" id="goalText"></span>
                        <button class="btn btn-sm btn-outline-primary ml-2" data-toggle="modal" data-target="#setGoalModal" title="Definir meta"><i class="fas fa-edit"></i></button>
                      </div>
                    </div>
                    <div class="progress" style="height:22px; border-radius:12px;">
                      <div class="progress-bar" id="goalBar" role="progressbar" style="width:0%; border-radius:12px; font-weight:700;"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-1 small text-muted">
                      <span id="goalCurrent"></span>
                      <span id="goalRemaining"></span>
                    </div>
                  </div>
                </div>

                <!-- Set Goal Modal -->
                <div class="modal fade" id="setGoalModal" tabindex="-1">
                  <div class="modal-dialog modal-sm">
                    <div class="modal-content">
                      <div class="modal-header py-2">
                        <h6 class="modal-title font-weight-bold"><i class="fas fa-bullseye mr-1 text-primary"></i>Definir meta mensal</h6>
                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                      </div>
                      <div class="modal-body">
                        <div class="form-group">
                          <label class="small font-weight-bold">Valor da meta (MZN)</label>
                          <input type="number" class="form-control" id="goalAmountInput" min="0" step="1000" placeholder="Ex: 200000"/>
                        </div>
                      </div>
                      <div class="modal-footer py-2">
                        <button class="btn btn-primary btn-sm" onclick="saveGoal()"><i class="fas fa-save mr-1"></i>Guardar</button>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="row">
                  <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-left-primary shadow h-100 py-2">
                      <div class="card-body">
                        <div class="row no-gutters align-items-center">
                          <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                              Total vendido
                            </div>
                            <div class="h6 mb-0 font-weight-bold text-gray-800" id="total-sold"></div>
                          </div>
                          <div class="col-auto">
                            <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-left-success shadow h-100 py-2">
                      <div class="card-body">
                        <div class="row no-gutters align-items-center">
                          <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                              Nº de vendas
                            </div>
                            <div class="h6 mb-0 font-weight-bold text-gray-800" id="total-sales"></div>
                          </div>
                          <div class="col-auto">
                            <i class="fas fa-cart-shopping fa-2x text-gray-300"></i>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-left-info shadow h-100 py-2">
                      <div class="card-body">
                        <div class="row no-gutters align-items-center">
                          <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                              Última venda
                            </div>
                            <div class="h6 mb-0 font-weight-bold text-gray-800" id="last-sale"></div>
                          </div>
                          <div class="col-auto">
                            <i class="fas fa-receipt fa-2x text-gray-300"></i>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-left-warning shadow h-100 py-2">
                      <div class="card-body">
                        <div class="row no-gutters align-items-center">
                          <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                              Vendas canceladas
                            </div>
                            <div class="h6 mb-0 font-weight-bold text-gray-800" id="cancelled-sales"></div>
                          </div>
                          <div class="col-auto">
                            <i class="fas fa-ban fa-2x text-gray-300"></i>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="row">
                  <div class="col-xl-8 col-lg-7">
                    <div class="card shadow mb-4">
                      <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">
                          Vendas por dia
                        </h6>
                      </div>
                      <div class="card-body">
                        <div class="chart-area">
                          <canvas id="salesAreaChart"></canvas>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-xl-4 col-lg-5">
                    <div class="card shadow mb-4">
                      <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary">
                          Métodos de pagamento
                        </h6>
                      </div>
                      <div class="card-body">
                        <div class="chart-pie pt-4 pb-2">
                          <canvas id="paymentsPieChart"></canvas>
                        </div>
                        <div class="mt-4 text-center small" id="paymentLegend"></div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Insights + Profit + Savings -->
                <div class="row">
                  <!-- Insights -->
                  <div class="col-xl-6 col-lg-6 mb-4">
                    <div class="card shadow h-100">
                      <div class="card-header py-2">
                        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-lightbulb mr-1 text-warning"></i>Insights</h6>
                      </div>
                      <div class="card-body" id="insightsList">
                        <p class="text-muted small">A analisar...</p>
                      </div>
                    </div>
                  </div>

                  <!-- Profit overview -->
                  <div class="col-xl-3 col-lg-3 mb-4">
                    <div class="card shadow h-100">
                      <div class="card-header py-2">
                        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-chart-pie mr-1"></i>Lucro do mês</h6>
                      </div>
                      <div class="card-body text-center">
                        <div class="small text-muted mb-1">Receita</div>
                        <div class="h5 text-success font-weight-bold" id="profitRevenue">—</div>
                        <div class="small text-muted mb-1">Despesas</div>
                        <div class="h5 text-danger font-weight-bold" id="profitExpenses">—</div>
                        <hr/>
                        <div class="small text-muted mb-1">Lucro</div>
                        <div class="h4 font-weight-bold" id="profitNet" style="color:#228CDF;">—</div>
                      </div>
                    </div>
                  </div>

                  <!-- Savings -->
                  <div class="col-xl-3 col-lg-3 mb-4">
                    <div class="card shadow h-100 border-left-success">
                      <div class="card-header py-2">
                        <h6 class="m-0 font-weight-bold text-success"><i class="fas fa-clock mr-1"></i>Quanto poupaste</h6>
                      </div>
                      <div class="card-body text-center">
                        <div class="h3 font-weight-bold text-success" id="savingsHours">—</div>
                        <div class="small text-muted mb-2">horas poupadas este mês</div>
                        <div class="small" id="savingsDetails"></div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Stock Alerts + Debts -->
                <div class="row">
                  <!-- Low Stock -->
                  <div class="col-xl-6 col-lg-6 mb-4">
                    <div class="card shadow h-100">
                      <div class="card-header py-2 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-warning"><i class="fas fa-exclamation-triangle mr-1"></i>Stock Baixo</h6>
                        <a href="/products" class="btn btn-sm btn-outline-warning">Ver produtos</a>
                      </div>
                      <div class="card-body p-0" id="lowStockList">
                        <p class="text-muted text-center py-3 small">A verificar...</p>
                      </div>
                    </div>
                  </div>

                  <!-- Top Debts -->
                  <div class="col-xl-6 col-lg-6 mb-4">
                    <div class="card shadow h-100">
                      <div class="card-header py-2 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-danger"><i class="fas fa-hand-holding-usd mr-1"></i>Quem me deve</h6>
                        <a href="/debts" class="btn btn-sm btn-outline-danger">Ver todas</a>
                      </div>
                      <div class="card-body p-0" id="debtsSummary">
                        <p class="text-muted text-center py-3 small">A verificar...</p>
                      </div>
                    </div>
                  </div>
                </div>
            </div>
        </div>

        <%- include('partials/copyright') %>
      </div>
  </div>

  <a class="scroll-to-top rounded" href="#page-top">
    <i class="fas fa-angle-up"></i>
  </a>

  <%- include('partials/footer') %>

    <script src="/assets/vendor/chart.js/Chart.min.js"></script>
    <script src="/assets/js/sales-dashboard.js"></script>
    <script>
      function checkSubscriptionStatus() {
        fetch('/api/subscriptions/my', { cache: 'no-store' })
          .then(r => r.ok ? r.json() : null)
          .then(data => {
            if (!data || !data.success) return;

            const s = data.subscription || {};
            const days = Number(s.daysLeft || 0);

            const expiredBanner = document.getElementById('subExpiredBanner');
            const warningBanner = document.getElementById('subWarningBanner');

            const isExpired = s.status === 'expired' || days <= 0;
            const showWarning = s.status === 'active' && days > 0 && days <= 7;

            expiredBanner.style.display = 'none';
            warningBanner.style.display = 'none';

            if (isExpired) {
              expiredBanner.style.display = 'flex';
            } else if (showWarning) {
              document.getElementById('subDaysLeft').textContent = days;
              warningBanner.style.display = 'flex';
            }
          })
          .catch(console.error);
      }
      checkSubscriptionStatus();

      // Sales Goal
      fetch('/api/features/sales-goal').then(function(r){return r.json();}).then(function(d) {
        if (!d.success) return;
        var card = document.getElementById('salesGoalCard');
        if (d.goal) {
          card.style.display = '';
          var pct = d.percentage;
          var bar = document.getElementById('goalBar');
          bar.style.width = pct + '%';
          bar.textContent = pct + '%';
          bar.className = 'progress-bar' + (pct >= 100 ? ' bg-success' : pct >= 60 ? ' bg-primary' : ' bg-warning');
          document.getElementById('goalText').textContent = cur(d.goal.targetAmount) + ' — ' + d.daysLeft + ' dias restantes';
          document.getElementById('goalCurrent').textContent = 'Actual: ' + cur(d.current);
          document.getElementById('goalRemaining').textContent = pct >= 100 ? 'Meta atingida!' : 'Faltam: ' + cur(d.remaining);
          document.getElementById('goalAmountInput').value = d.goal.targetAmount;
        } else {
          card.style.display = '';
          document.getElementById('goalText').textContent = 'Nenhuma meta definida';
          document.getElementById('goalBar').style.width = '0%';
          document.getElementById('goalCurrent').textContent = '';
          document.getElementById('goalRemaining').textContent = '';
        }
      }).catch(function(){});

      async function saveGoal() {
        var amount = parseFloat(document.getElementById('goalAmountInput').value);
        if (!amount || amount <= 0) return alert('Valor inválido.');
        await fetch('/api/features/sales-goal', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({targetAmount:amount}) });
        $('#setGoalModal').modal('hide');
        window.location.reload();
      }
      window.saveGoal = saveGoal;

      var cur = function(v) { return new Intl.NumberFormat('pt-MZ',{style:'currency',currency:'MZN'}).format(v||0); };

      // Insights
      fetch('/api/dashboard/insights').then(function(r){return r.json();}).then(function(d) {
        if (!d.success || !d.insights.length) { document.getElementById('insightsList').innerHTML = '<p class="text-muted small">Sem insights por agora.</p>'; return; }
        document.getElementById('insightsList').innerHTML = d.insights.map(function(i) {
          return '<div class="d-flex align-items-start mb-2" style="gap:8px;"><i class="' + i.icon + ' text-' + i.color + ' mt-1"></i><span class="small">' + i.text + '</span></div>';
        }).join('');
      }).catch(function(){});

      // Profit
      fetch('/api/dashboard/profit').then(function(r){return r.json();}).then(function(d) {
        if (!d.success) return;
        document.getElementById('profitRevenue').textContent = cur(d.overview.revenue);
        document.getElementById('profitExpenses').textContent = cur(d.overview.expenses);
        var net = document.getElementById('profitNet');
        net.textContent = cur(d.overview.profit);
        net.style.color = d.overview.profit >= 0 ? '#1cc88a' : '#e74a3b';
      }).catch(function(){});

      // Savings
      fetch('/api/dashboard/savings').then(function(r){return r.json();}).then(function(d) {
        if (!d.success) return;
        document.getElementById('savingsHours').textContent = d.stats.hoursSaved;
        document.getElementById('savingsDetails').innerHTML =
          '<div>' + d.stats.invoicesThisMonth + ' facturas emitidas</div>'
          + '<div>' + d.stats.salesThisMonth + ' vendas registadas</div>'
          + '<div>' + d.stats.totalProducts + ' produtos geridos</div>';
      }).catch(function(){});

      // Low Stock
      fetch('/api/dashboard/low-stock').then(function(r){return r.json();}).then(function(d) {
        var el = document.getElementById('lowStockList');
        if (!d.success || !d.products.length) { el.innerHTML = '<p class="text-success text-center py-3 small"><i class="fas fa-check-circle mr-1"></i>Stock OK</p>'; return; }
        el.innerHTML = '<div class="table-responsive"><table class="table table-sm mb-0"><tbody>'
          + d.products.map(function(p) {
            return '<tr><td class="font-weight-bold small">' + p.description + '</td>'
              + '<td><span class="badge badge-danger">' + p.stock.quantity + ' ' + (p.unit||'un') + '</span></td>'
              + '<td class="small text-muted">mín: ' + (p.stock.min||0) + '</td></tr>';
          }).join('') + '</tbody></table></div>';
      }).catch(function(){});

      // Debts
      fetch('/api/dashboard/client-debts').then(function(r){return r.json();}).then(function(d) {
        var el = document.getElementById('debtsSummary');
        if (!d.success || !d.debts.length) { el.innerHTML = '<p class="text-success text-center py-3 small"><i class="fas fa-check-circle mr-1"></i>Sem dívidas</p>'; return; }
        el.innerHTML = '<div class="table-responsive"><table class="table table-sm mb-0"><tbody>'
          + d.debts.slice(0,5).map(function(debt) {
            return '<tr><td class="font-weight-bold small">' + debt._id + '</td>'
              + '<td class="text-danger font-weight-bold small">' + cur(debt.totalDebt) + '</td>'
              + '<td><span class="badge badge-secondary">' + debt.invoiceCount + ' doc' + (debt.invoiceCount>1?'s':'') + '</span></td></tr>';
          }).join('') + '</tbody></table></div>'
          + '<div class="text-center small py-1"><strong class="text-danger">Total: ' + cur(d.totalDebt) + '</strong></div>';
      }).catch(function(){});
    </script>
</body>

</html>