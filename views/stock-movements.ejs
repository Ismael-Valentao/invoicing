<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

  <title>Invoicing | <%- title %></title>
  <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png" />

  <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
  <link
    href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />

  <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet">
  <link href="/assets/vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet">
  <link href="/assets/css/custom.css" rel="stylesheet" />

  <style>
    body {
      font-size: 0.85rem !important;
    }

    table {
      font-size: 0.8rem !important;
    }

    table tr th,
    table tr td {
      padding: 0.35rem !important;
      vertical-align: middle !important;
    }

    /* =========================
   MOBILE CARDS (Stock Movements)
   ========================= */
    #stockMovementsMobileList .mv-card {
      border: 1px solid rgba(0, 0, 0, .08);
      border-radius: 14px;
      padding: 12px 12px;
      background: #fff;
      box-shadow: 0 2px 12px rgba(0, 0, 0, .04);
      margin-bottom: 10px;
    }

    #stockMovementsMobileList .mv-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
    }

    #stockMovementsMobileList .mv-product {
      font-weight: 700;
      font-size: .95rem;
      line-height: 1.2;
      color: #2d3748;
    }

    #stockMovementsMobileList .mv-date {
      font-size: .78rem;
      color: #718096;
      white-space: nowrap;
    }

    #stockMovementsMobileList .mv-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 8px;
    }

    #stockMovementsMobileList .mv-pill {
      font-size: .78rem;
      padding: 4px 10px;
      border-radius: 999px;
      background: #f1f5f9;
      color: #334155;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    #stockMovementsMobileList .mv-pill code {
      font-size: .78rem;
      padding: 0;
      background: transparent;
    }

    #stockMovementsMobileList .mv-type {
      font-weight: 700;
    }

    #stockMovementsMobileList .mv-type.in {
      color: #1b8f3a;
    }

    #stockMovementsMobileList .mv-type.out {
      color: #c53030;
    }

    #stockMovementsMobileList .mv-type.adj {
      color: #b7791f;
    }

    #stockMovementsMobileList .mv-qty {
      font-weight: 800;
      font-size: 1.05rem;
    }

    #stockMovementsMobileList .mv-reason {
      font-size: .82rem;
      color: #4a5568;
      background: #f8fafc;
      border-radius: 10px;
      padding: 8px 10px;
    }

    /* opcional: filtros mais “mobile friendly” */
    @media (max-width: 768px) {
      .page-content .container-fluid {
        padding-left: .75rem;
        padding-right: .75rem;
      }

      .card-body {
        padding: .9rem;
      }

      label {
        margin-bottom: .3rem;
        font-weight: 600;
      }
    }

    #stockMovementsMobileList .mv-card {
      border: 1px solid rgba(0, 0, 0, .08);
      border-radius: 14px;
      padding: 12px;
      background: #fff;
      box-shadow: 0 2px 12px rgba(0, 0, 0, .04);
      margin-bottom: 10px;
    }

    #stockMovementsMobileList .mv-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
    }

    #stockMovementsMobileList .mv-product {
      font-weight: 700;
      font-size: .95rem;
      color: #2d3748;
      line-height: 1.2;
    }

    #stockMovementsMobileList .mv-date {
      font-size: .78rem;
      color: #718096;
      white-space: nowrap;
    }

    #stockMovementsMobileList .mv-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 8px;
    }

    #stockMovementsMobileList .mv-pill {
      font-size: .78rem;
      padding: 4px 10px;
      border-radius: 999px;
      background: #f1f5f9;
      color: #334155;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    #stockMovementsMobileList .mv-pill code {
      font-size: .78rem;
      background: transparent;
      padding: 0;
    }

    #stockMovementsMobileList .mv-type {
      font-weight: 700;
    }

    #stockMovementsMobileList .mv-type.in {
      color: #1b8f3a;
    }

    #stockMovementsMobileList .mv-type.out {
      color: #c53030;
    }

    #stockMovementsMobileList .mv-type.adj {
      color: #b7791f;
    }

    #stockMovementsMobileList .mv-qty {
      font-weight: 800;
      font-size: 1.05rem;
    }

    #stockMovementsMobileList .mv-reason {
      font-size: .82rem;
      color: #4a5568;
      background: #f8fafc;
      border-radius: 10px;
      padding: 8px 10px;
    }

    @media (max-width: 768px) {
      #btnMobileLoadMore {
        border-radius: 12px;
        padding: 10px 12px;
        font-weight: 700;
      }
    }
  </style>
</head>

<body id="page-top">
  <div id="wrapper">
    <%- include('partials/sidebar') %>

      <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
          <%- include('partials/topbar') %>
            
              <div class="container-fluid">

                <div class="d-sm-flex align-items-center justify-content-between mb-3">
                  <h5 class="mb-0 text-gray-800">Movimentos de Stock</h5>
                </div>

                <!-- Filtros -->
                <div class="card shadow mb-3">
                  <div class="card-body">
                    <div class="row">
                      <div class="form-group col-md-5">
                        <label>Produto</label>
                        <select class="form-control form-control-sm" id="filterProduct">
                          <option value="">Todos</option>
                        </select>
                      </div>

                      <div class="form-group col-md-3">
                        <label>Tipo</label>
                        <select class="form-control form-control-sm" id="filterType">
                          <option value="">Todos</option>
                          <option value="IN">Entrada</option>
                          <option value="OUT">Saída</option>
                          <option value="ADJUST">Ajuste</option>
                        </select>
                      </div>

                      <div class="form-group col-md-2">
                        <label>De</label>
                        <input type="date" class="form-control form-control-sm" id="filterStartDate">
                      </div>

                      <div class="form-group col-md-2">
                        <label>Até</label>
                        <input type="date" class="form-control form-control-sm" id="filterEndDate">
                      </div>

                      <div class="form-group col-md-12 d-flex justify-content-end" style="gap:10px;">
                        <button class="btn btn-secondary btn-sm" id="btnClearFilters" type="button">
                          Limpar
                        </button>
                        <button class="btn btn-primary btn-sm" id="btnApplyFilters" type="button">
                          Filtrar
                        </button>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Tabela -->
                <div class="card shadow mb-4">
                  <div class="card-body">
                    <!-- MOBILE: lista/cards (gerado via JS) -->
                    <div id="stockMovementsMobileList" class="d-md-none"></div>
                    <div class="table-responsive d-none d-md-block">
                      <table class="table table-bordered" id="stockMovementsTable" width="100%" cellspacing="0">
                        <thead>
                          <tr class="bg-secondary text-white">
                            <th>Data</th>
                            <th>Produto</th>
                            <th class="text-center">Código</th>
                            <th class="text-center">Tipo</th>
                            <th class="text-center">Qtd.</th>
                            <th>Motivo</th>
                          </tr>
                        </thead>
                        <tbody></tbody>
                      </table>
                    </div>
                  </div>
                </div>

              </div>
            </div>
        <%- include('partials/copyright') %>
      </div>
  </div>

  <a class="scroll-to-top rounded" href="#page-top">
    <i class="fas fa-angle-up"></i>
  </a>

  <%- include('partials/footer') %>

    <script src="/assets/vendor/datatables/jquery.dataTables.min.js"></script>
    <script src="/assets/vendor/datatables/dataTables.bootstrap4.min.js"></script>

    <script src="/assets/js/stock-movements.js"></script>
</body>

</html>