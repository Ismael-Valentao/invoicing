<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Invoicing - Forgot Password</title>
    <link rel="icon" type="image/png" href="images/invoicing-logo-simple.png" />

    <link href="assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
        rel="stylesheet">
    <link href="assets/css/sb-admin-2.min.css" rel="stylesheet" />

    <style>
        :root {
            --bg1: #0b4bff;
            --bg2: #6a5cff;
            --text: #111827;
            --muted: #6b7280;
            --line: #e5e7eb;
            --shadow: 0 22px 70px rgba(16, 24, 40, .20);
            --radius: 18px;
        }

        body.bg-gradient-primary {
            background: radial-gradient(1200px 600px at 15% 10%, rgba(255, 255, 255, .20), transparent 55%),
                radial-gradient(900px 520px at 85% 15%, rgba(255, 255, 255, .18), transparent 60%),
                linear-gradient(135deg, var(--bg1), var(--bg2)) !important;
            min-height: 100vh;
        }

        .auth-wrap {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 28px 0;
        }

        .auth-card {
            border: 1px solid rgba(255, 255, 255, .22) !important;
            border-radius: var(--radius) !important;
            overflow: hidden;
            background: rgba(255, 255, 255, .92);
            backdrop-filter: blur(8px);
            box-shadow: var(--shadow);
        }

        .auth-head {
            padding: 18px 22px;
            border-bottom: 1px solid rgba(229, 231, 235, .8);
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand img {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            box-shadow: 0 8px 18px rgba(16, 24, 40, .10);
        }

        .brand .t1 {
            font-weight: 900;
            color: var(--text);
            line-height: 1.1;
        }

        .brand .t2 {
            font-size: .85rem;
            color: var(--muted);
            margin-top: 1px;
        }

        .auth-body {
            padding: 22px;
            background: #fff;
        }

        .title {
            font-weight: 900;
            color: var(--text);
            margin: 0 0 6px;
            font-size: 0.9rem;
            text-align: center;
        }

        .subtitle {
            color: var(--muted);
            font-size: .85rem;
            text-align: center;
            margin-bottom: 14px;
        }

        .iwrap {
            position: relative;
        }

        .iwrap .icon {
            position: absolute;
            top: 50%;
            left: 14px;
            transform: translateY(-50%);
            color: #9ca3af;
            pointer-events: none;
        }

        input.form-control {
            border-radius: 14px !important;
            padding: 1.05rem .95rem !important;
            border: 1px solid #e5e7eb !important;
            background: #fff !important;
        }

        .iwrap input.form-control {
            padding-left: 44px !important;
        }

        input.form-control:focus {
            border-color: rgba(37, 99, 235, .55) !important;
            box-shadow: 0 0 0 .18rem rgba(37, 99, 235, .12) !important;
        }

        .btn-user {
            border-radius: 14px !important;
            padding: .70rem 1.1rem !important;
            font-weight: 800;
            box-shadow: 0 12px 30px rgba(37, 99, 235, .22);
        }

        #errorBox {
            border-radius: 14px;
            border: 1px solid rgba(220, 53, 69, .25);
        }

        .muted-link {
            color: #374151;
            font-weight: 800;
            text-decoration: none;
        }

        .muted-link:hover {
            text-decoration: underline;
        }

        .foot-note {
            text-align: center;
            margin-top: 14px;
            color: rgba(255, 255, 255, .85);
            font-size: .9rem;
        }

        .foot-note a {
            color: #fff;
            font-weight: 900;
            text-decoration: underline;
        }
        input[type="text"]{
            font-size: 12px;
        }
    </style>
</head>

<body class="bg-gradient-primary">
    <div class="auth-wrap">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-5">
                    <div class="card auth-card border-0">
                        <div class="auth-head">
                            <div class="brand">
                                <img src="images/invoicing-logo-simple.png" alt="logo">
                                <div>
                                    <div class="t1">Recuperar acesso</div>
                                    <div class="t2">Vamos enviar um link por email</div>
                                </div>
                            </div>
                            <span class="badge badge-light"
                                style="border:1px solid var(--line); border-radius:999px; padding:8px 10px;">
                                <i class="fas fa-shield-alt mr-1"></i> Seguro
                            </span>
                        </div>

                        <div class="auth-body">
                            <h5 class="title">Esqueci a palavra-passe</h5>
                            <div class="subtitle">Digite o teu email e enviaremos um link para redefinir.</div>

                            <div id="errorBox" class="alert alert-danger d-none text-center" role="alert"></div>
                            <div id="successBox" class="alert alert-success d-none text-center" role="alert"></div>

                            <form id="forgotForm" autocomplete="on">
                                <div class="form-group">
                                    <label class="font-weight-bold">E-mail</label>
                                    <div class="iwrap">
                                        <i class="fas fa-envelope icon"></i>
                                        <input type="email" class="form-control" id="email"
                                            placeholder="yourname@example.com" required autocomplete="email">
                                    </div>
                                </div>

                                <button type="submit" id="btnSend" class="btn btn-primary btn-user btn-block">
                                    Enviar link <i class="fas fa-paper-plane ml-2"></i>
                                </button>

                                <div class="text-center mt-3">
                                    <a class="muted-link small" href="/login"><i
                                            class="fas fa-arrow-left mr-2"></i>Voltar ao login</a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="foot-note">
                        Invoicing © <%= new Date().getFullYear() %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="assets/vendor/jquery/jquery.min.js"></script>
    <script src="assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="assets/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="assets/js/sb-admin-2.min.js"></script>

    <script>
        (function () {
            const form = document.getElementById("forgotForm");
            const email = document.getElementById("email");
            const btn = document.getElementById("btnSend");
            const errorBox = document.getElementById("errorBox");
            const successBox = document.getElementById("successBox");

            function show(box, msg) {
                box.textContent = msg;
                box.classList.remove("d-none");
            }
            function hide(box) { box.classList.add("d-none"); box.textContent = ""; }

            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                hide(errorBox); hide(successBox);

                btn.disabled = true;
                btn.innerHTML = 'Enviando... <i class="fas fa-spinner fa-spin ml-2"></i>';

                try {
                    const resp = await fetch("/api/users/passwords/forgot-password", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ email: email.value.trim() })
                    });
                    const data = await resp.json().catch(() => ({}));

                    if (!resp.ok) {
                        btn.disabled = false;
                        btn.innerHTML = 'Enviar link <i class="fas fa-paper-plane ml-2"></i>';
                        return show(errorBox, data.message || "Não foi possível processar o pedido.");
                    }

                    // Sempre responde de forma genérica (não revela se existe)
                    show(successBox, data.message || "Se este e-mail existir no sistema, você receberá um link de redefinição.");
                    btn.innerHTML = 'Link enviado <i class="fas fa-check ml-2"></i>';
                } catch (err) {
                    btn.disabled = false;
                    btn.innerHTML = 'Enviar link <i class="fas fa-paper-plane ml-2"></i>';
                    show(errorBox, "Falha de conexão. Tente novamente.");
                }
            });
        })();
    </script>
</body>

</html>