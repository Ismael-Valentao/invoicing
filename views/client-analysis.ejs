<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>
  <title>Invoicing - <%- title %></title>
  <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png"/>
  <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,400,600,700,800" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous"/>
  <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet"/>
  <link href="/assets/css/custom.css" rel="stylesheet"/>
</head>
<body id="page-top">
<div id="wrapper">
  <%- include('partials/sidebar') %>
  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      <%- include('partials/topbar') %>
      <div class="container-fluid">
        <h5 class="mb-4 text-gray-800"><strong><i class="fas fa-users mr-2 text-primary"></i>Análise de Clientes</strong></h5>

        <div class="row">
          <!-- Top clients -->
          <div class="col-lg-6 mb-4">
            <div class="card shadow h-100">
              <div class="card-header py-2"><h6 class="m-0 font-weight-bold text-success"><i class="fas fa-trophy mr-1"></i>Top Clientes (30 dias)</h6></div>
              <div class="card-body p-0" id="topClientsList"><p class="text-muted text-center py-3">A carregar...</p></div>
            </div>
          </div>
          <!-- Inactive clients -->
          <div class="col-lg-6 mb-4">
            <div class="card shadow h-100">
              <div class="card-header py-2"><h6 class="m-0 font-weight-bold text-warning"><i class="fas fa-user-clock mr-1"></i>Clientes Inactivos (+30 dias)</h6></div>
              <div class="card-body p-0" id="inactiveClientsList"><p class="text-muted text-center py-3">A carregar...</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <%- include('partials/copyright') %>
  </div>
</div>
<%- include('partials/footer') %>
<script>
var cur = function(v) { return new Intl.NumberFormat('pt-MZ',{style:'currency',currency:'MZN'}).format(v||0); };
var catLabels = {final:'Final',revendedor:'Revendedor',grossista:'Grossista',vip:'VIP',outro:'Outro'};

fetch('/api/features/client-analysis').then(function(r){return r.json();}).then(function(data) {
  if (!data.success) return;

  // Top clients
  var topEl = document.getElementById('topClientsList');
  if (!data.topClients.length) {
    topEl.innerHTML = '<p class="text-muted text-center py-3">Sem dados suficientes.</p>';
  } else {
    topEl.innerHTML = '<div class="table-responsive"><table class="table table-sm mb-0"><thead class="thead-light"><tr><th>#</th><th>Cliente</th><th>Compras</th><th>Total</th></tr></thead><tbody>'
      + data.topClients.map(function(c, i) {
        return '<tr><td class="font-weight-bold">' + (i+1) + '</td><td>' + (c.name||'Sem nome') + '</td><td>' + c.purchases + '</td><td class="font-weight-bold text-success">' + cur(c.totalSpent) + '</td></tr>';
      }).join('') + '</tbody></table></div>';
  }

  // Inactive
  var inEl = document.getElementById('inactiveClientsList');
  if (!data.inactiveClients.length) {
    inEl.innerHTML = '<p class="text-success text-center py-3"><i class="fas fa-check-circle mr-1"></i>Todos os clientes estão activos!</p>';
  } else {
    inEl.innerHTML = '<div class="table-responsive"><table class="table table-sm mb-0"><thead class="thead-light"><tr><th>Cliente</th><th>Categoria</th><th>Contacto</th><th></th></tr></thead><tbody>'
      + data.inactiveClients.map(function(c) {
        var whatsapp = c.phone ? 'https://wa.me/' + c.phone.replace(/[^0-9]/g,'') + '?text=' + encodeURIComponent('Olá ' + c.name + ', sentimos a sua falta! Temos novidades para si.') : '#';
        return '<tr><td class="font-weight-bold">' + c.name + '</td><td><span class="badge badge-secondary">' + (catLabels[c.category]||'Final') + '</span></td>'
          + '<td class="small">' + (c.phone||c.email||'—') + '</td>'
          + '<td><a href="' + whatsapp + '" target="_blank" class="btn btn-outline-success btn-sm"><i class="fab fa-whatsapp"></i></a></td></tr>';
      }).join('') + '</tbody></table></div>';
  }
}).catch(function(){});
</script>
</body>
</html>
