<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>
  <title>Invoicing - <%- title %></title>
  <link rel="icon" type="image/png" href="images/invoicing-logo-simple.png"/>
  <link href="assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,400,600,700,800" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous"/>
  <link href="assets/css/sb-admin-2.min.css" rel="stylesheet"/>
  <link href="assets/css/custom.css" rel="stylesheet"/>
</head>
<body id="page-top">
<div id="wrapper">
  <%- include('partials/sidebar') %>
  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      <%- include('partials/topbar') %>
      <div class="container-fluid">
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
          <h5 class="mb-0 text-gray-800"><strong><i class="fas fa-file-circle-minus mr-2"></i>Notas de Crédito & Débito</strong></h5>
          <div class="d-flex" style="gap:8px;">
            <select id="filterType" class="form-control form-control-sm" style="width:auto;" onchange="loadNotes()">
              <option value="">Todas</option>
              <option value="credit_note">Notas de Crédito</option>
              <option value="debit_note">Notas de Débito</option>
            </select>
            <button class="btn btn-sm btn-primary" data-toggle="modal" data-target="#newDebitNoteModal">
              <i class="fas fa-plus mr-1"></i>Nova Nota de Débito
            </button>
          </div>
        </div>

        <div class="card shadow mb-4">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="thead-light">
                  <tr>
                    <th>Nº</th>
                    <th>Tipo</th>
                    <th>Cliente</th>
                    <th>Factura Ref.</th>
                    <th>Valor</th>
                    <th>Motivo</th>
                    <th>Data</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody id="notesTbody">
                  <tr><td colspan="8" class="text-center text-muted py-3">A carregar...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="alert alert-info small">
          <i class="fas fa-info-circle mr-1"></i>
          <strong>Nota de Crédito:</strong> emitida automaticamente ao anular uma factura (botão <i class="fas fa-ban"></i> na lista de facturas).<br/>
          <strong>Nota de Débito:</strong> emitida manualmente quando é necessário acrescentar valor a uma factura existente.
        </div>
      </div>
    </div>
    <%- include('partials/copyright') %>
  </div>
</div>

<!-- New Debit Note Modal -->
<div class="modal fade" id="newDebitNoteModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-file-circle-plus mr-2 text-warning"></i>Nova Nota de Débito</h5>
        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
      </div>
      <div class="modal-body">
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label class="small font-weight-bold">Factura de referência *</label>
              <select class="form-control form-control-sm" id="ndInvoice">
                <option value="">Seleccione...</option>
              </select>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-group">
              <label class="small font-weight-bold">Motivo *</label>
              <input type="text" class="form-control form-control-sm" id="ndReason" placeholder="Ex: Item adicional não incluído na factura"/>
            </div>
          </div>
        </div>
        <hr/>
        <h6 class="font-weight-bold">Itens a debitar</h6>
        <div id="ndItems">
          <div class="row mb-2 nd-item">
            <div class="col-6"><input type="text" class="form-control form-control-sm" placeholder="Descrição" data-field="description"/></div>
            <div class="col-2"><input type="number" class="form-control form-control-sm" placeholder="Qtd" data-field="quantity" value="1" min="1"/></div>
            <div class="col-3"><input type="number" class="form-control form-control-sm" placeholder="Preço" data-field="unitPrice" step="0.01" min="0"/></div>
            <div class="col-1"><button class="btn btn-sm btn-outline-danger" onclick="this.closest('.nd-item').remove()">&times;</button></div>
          </div>
        </div>
        <button class="btn btn-sm btn-outline-primary mt-1" onclick="addNdItem()"><i class="fas fa-plus mr-1"></i>Adicionar item</button>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-warning btn-sm" onclick="saveDebitNote()">
          <i class="fas fa-file-circle-plus mr-1"></i>Emitir Nota de Débito
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
var currency = function(v) { return new Intl.NumberFormat('pt-MZ',{style:'currency',currency:'MZN'}).format(v||0); };

function addNdItem() {
  var html = '<div class="row mb-2 nd-item">'
    + '<div class="col-6"><input type="text" class="form-control form-control-sm" placeholder="Descrição" data-field="description"/></div>'
    + '<div class="col-2"><input type="number" class="form-control form-control-sm" placeholder="Qtd" data-field="quantity" value="1" min="1"/></div>'
    + '<div class="col-3"><input type="number" class="form-control form-control-sm" placeholder="Preço" data-field="unitPrice" step="0.01" min="0"/></div>'
    + '<div class="col-1"><button class="btn btn-sm btn-outline-danger" onclick="this.closest(\'.nd-item\').remove()">&times;</button></div></div>';
  document.getElementById('ndItems').insertAdjacentHTML('beforeend', html);
}

// Load invoices for the debit note dropdown
fetch('/api/invoices').then(r => r.json()).then(data => {
  var sel = document.getElementById('ndInvoice');
  (data.invoices || []).filter(function(i) { return i.status !== 'cancelled'; }).forEach(function(inv) {
    sel.innerHTML += '<option value="' + inv._id + '">' + inv.invoiceNumber + ' — ' + inv.clientName + '</option>';
  });
}).catch(function(){});

function loadNotes() {
  var type = document.getElementById('filterType').value;
  var url = '/api/invoices/notes' + (type ? '?type=' + type : '');
  fetch(url).then(function(r) { return r.json(); }).then(function(data) {
    var tbody = document.getElementById('notesTbody');
    if (!data.success || !data.notes.length) {
      tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-3">Sem notas emitidas.</td></tr>';
      return;
    }
    tbody.innerHTML = data.notes.map(function(n) {
      var typeBadge = n.docType === 'credit_note'
        ? '<span class="badge badge-dark">NC</span>'
        : '<span class="badge badge-warning text-dark">ND</span>';
      var refNumber = n.relatedInvoiceId?.invoiceNumber || '—';
      return '<tr>'
        + '<td class="font-weight-bold">' + n.invoiceNumber + '</td>'
        + '<td>' + typeBadge + '</td>'
        + '<td>' + n.clientName + '</td>'
        + '<td><small>' + refNumber + '</small></td>'
        + '<td class="font-weight-bold">' + currency(n.totalAmount) + '</td>'
        + '<td class="small">' + (n.reason || '—') + '</td>'
        + '<td class="small">' + new Date(n.date).toLocaleDateString('pt-PT') + '</td>'
        + '<td><a href="/api/invoices/' + n._id + '/pdf" class="btn btn-primary btn-sm" title="Baixar PDF"><i class="fas fa-download"></i></a></td>'
        + '</tr>';
    }).join('');
  }).catch(function(){
    document.getElementById('notesTbody').innerHTML = '<tr><td colspan="8" class="text-center text-danger py-3">Erro ao carregar.</td></tr>';
  });
}

async function saveDebitNote() {
  var invoiceId = document.getElementById('ndInvoice').value;
  var reason = document.getElementById('ndReason').value.trim();
  if (!invoiceId) return alert('Seleccione uma factura.');
  if (!reason) return alert('Motivo é obrigatório.');
  var items = [];
  document.querySelectorAll('.nd-item').forEach(function(row) {
    var desc = row.querySelector('[data-field="description"]').value;
    var qty = parseFloat(row.querySelector('[data-field="quantity"]').value) || 1;
    var price = parseFloat(row.querySelector('[data-field="unitPrice"]').value) || 0;
    if (desc && price > 0) items.push({ description: desc, quantity: qty, unitPrice: price });
  });
  if (!items.length) return alert('Adicione pelo menos um item.');

  try {
    var res = await fetch('/api/invoices/debit-note', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ invoiceId: invoiceId, reason: reason, items: items })
    });
    var data = await res.json();
    if (data.success) {
      $('#newDebitNoteModal').modal('hide');
      if (typeof Swal !== 'undefined') {
        Swal.fire({ icon: 'success', title: 'Nota de Débito emitida', text: data.message, timer: 2500 });
      }
      loadNotes();
    } else {
      alert(data.message);
    }
  } catch (e) { alert('Erro de ligação.'); }
}

loadNotes();
</script>
</body>
</html>
