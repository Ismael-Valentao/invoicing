<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Invoicing — Configurar Empresa</title>
  <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png">
  <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css?family=Nunito:400,600,700,800" rel="stylesheet">
  <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet">
  <link href="/assets/css/custom.css" rel="stylesheet">
  <style>
    .wizard-container { max-width: 600px; margin: 0 auto; }
    .wizard-step { display: none; }
    .wizard-step.active { display: block; }
    .wizard-progress { display: flex; justify-content: center; gap: 8px; margin-bottom: 24px; }
    .wizard-dot { width: 12px; height: 12px; border-radius: 50%; background: #e3e6f0; transition: all .3s; }
    .wizard-dot.active { background: #228CDF; transform: scale(1.3); }
    .wizard-dot.done { background: #1cc88a; }
    .welcome-icon { font-size: 3rem; color: #228CDF; margin-bottom: 12px; }
    .skip-link { color: #858796; font-size: .85rem; text-decoration: underline; cursor: pointer; }
  </style>
</head>
<body id="page-top">
<div id="wrapper">
  <%- include('partials/sidebar') %>
  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      <%- include('partials/topbar') %>
      <div class="container-fluid">
        <div class="wizard-container">

          <!-- Progress -->
          <div class="wizard-progress">
            <div class="wizard-dot active" id="dot1"></div>
            <div class="wizard-dot" id="dot2"></div>
            <div class="wizard-dot" id="dot3"></div>
          </div>

          <!-- Step 1: Welcome -->
          <div class="wizard-step active" id="step1">
            <div class="card shadow text-center p-5">
              <div class="welcome-icon"><i class="fas fa-hand-sparkles"></i></div>
              <h3 class="font-weight-bold">Bem-vindo ao Invoicing, <%- name %>!</h3>
              <p class="text-muted mt-2 mb-4">Vamos configurar a tua empresa em 2 minutos. Isto permite que os teus documentos (facturas, recibos, etc.) saiam com os dados correctos.</p>
              <button class="btn btn-primary btn-lg" onclick="goStep(2)" style="border-radius:30px;">
                <i class="fas fa-arrow-right mr-2"></i>Configurar agora
              </button>
              <div class="mt-3">
                <span class="skip-link" onclick="skipSetup()">Configurar mais tarde</span>
              </div>
            </div>
          </div>

          <!-- Step 2: Company info -->
          <div class="wizard-step" id="step2">
            <div class="card shadow p-4">
              <h5 class="font-weight-bold mb-1"><i class="fas fa-building mr-2 text-primary"></i>Dados da empresa</h5>
              <p class="text-muted small mb-3">Estes dados aparecem nos documentos que emitir.</p>

              <div class="form-group">
                <label class="small font-weight-bold">Nome da empresa *</label>
                <input type="text" class="form-control" id="wCompanyName" placeholder="Ex: Loja do João, Lda"/>
              </div>
              <div class="row">
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="small font-weight-bold">NUIT *</label>
                    <input type="text" class="form-control" id="wNuit" placeholder="9 dígitos" maxlength="9"/>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="small font-weight-bold">Telefone *</label>
                    <input type="text" class="form-control" id="wContact" placeholder="Ex: 84 123 4567"/>
                  </div>
                </div>
              </div>
              <div class="form-group">
                <label class="small font-weight-bold">Morada</label>
                <input type="text" class="form-control" id="wAddress" placeholder="Ex: Av. 25 de Setembro, Maputo"/>
              </div>

              <div class="d-flex justify-content-between mt-3">
                <button class="btn btn-outline-secondary" onclick="goStep(1)"><i class="fas fa-arrow-left mr-1"></i>Voltar</button>
                <button class="btn btn-primary" onclick="saveCompanyAndNext()" id="btnSaveCompany">
                  <i class="fas fa-arrow-right mr-1"></i>Seguinte
                </button>
              </div>
            </div>
          </div>

          <!-- Step 3: All done -->
          <div class="wizard-step" id="step3">
            <div class="card shadow text-center p-5">
              <div style="font-size:3rem; color:#1cc88a; margin-bottom:12px;"><i class="fas fa-check-circle"></i></div>
              <h3 class="font-weight-bold">Tudo pronto!</h3>
              <p class="text-muted mt-2 mb-2">A tua empresa está configurada. Já criámos alguns dados de exemplo para começares:</p>
              <div class="d-flex justify-content-center gap-3 mb-4 flex-wrap" style="gap:12px;">
                <div class="text-center">
                  <div class="h4 font-weight-bold text-primary mb-0">3</div>
                  <small class="text-muted">Produtos</small>
                </div>
                <div class="text-center">
                  <div class="h4 font-weight-bold text-success mb-0">2</div>
                  <small class="text-muted">Clientes</small>
                </div>
              </div>
              <p class="small text-muted mb-4">Pode editar ou remover os dados de exemplo a qualquer momento.</p>
              <div class="d-flex justify-content-center flex-wrap" style="gap:8px;">
                <a href="/pos" class="btn btn-success" style="border-radius:25px;"><i class="fas fa-cash-register mr-1"></i>Fazer uma venda</a>
                <a href="/new-invoice" class="btn btn-primary" style="border-radius:25px;"><i class="fas fa-file-invoice mr-1"></i>Emitir factura</a>
                <a href="/dashboard" class="btn btn-outline-secondary" style="border-radius:25px;"><i class="fas fa-tachometer-alt mr-1"></i>Ir ao dashboard</a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
    <%- include('partials/copyright') %>
  </div>
</div>

<%- include('partials/footer') %>

<script>
var currentStep = 1;

function goStep(n) {
  document.querySelectorAll('.wizard-step').forEach(function(s) { s.classList.remove('active'); });
  document.getElementById('step' + n).classList.add('active');
  for (var i = 1; i <= 3; i++) {
    var dot = document.getElementById('dot' + i);
    dot.className = 'wizard-dot' + (i === n ? ' active' : i < n ? ' done' : '');
  }
  currentStep = n;
}

async function saveCompanyAndNext() {
  var name = document.getElementById('wCompanyName').value.trim();
  var nuit = document.getElementById('wNuit').value.trim();
  var contact = document.getElementById('wContact').value.trim();
  var address = document.getElementById('wAddress').value.trim() || 'A definir';

  if (!name) return alert('Nome da empresa é obrigatório.');
  if (!contact) return alert('Telefone é obrigatório.');

  var btn = document.getElementById('btnSaveCompany');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>A guardar...';

  try {
    var res = await fetch('/api/company', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ companyName: name, companyNUIT: nuit || '000000000', companyContact: contact, companyAddress: address, companyEmail: '' })
    });
    var data = await res.json();

    // Renovar o token para que o nome da empresa fique actualizado em todas as páginas
    await fetch('/api/auth/refresh-token', { method: 'POST' });

    goStep(3);
  } catch (e) {
    alert('Erro ao guardar. Tente novamente.');
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-arrow-right mr-1"></i>Seguinte';
}

function skipSetup() {
  window.location.href = '/dashboard';
}

// Load current company data
fetch('/api/company/company').then(function(r) { return r.json(); }).then(function(data) {
  var c = data.company || data;
  if (c.name && c.name !== 'A definir' && !c.name.startsWith('Empresa de ')) {
    document.getElementById('wCompanyName').value = c.name;
  }
  if (c.nuit && c.nuit !== '000000000') document.getElementById('wNuit').value = c.nuit;
  if (c.contact && c.contact !== 'A definir') document.getElementById('wContact').value = c.contact;
  if (c.address && c.address !== 'A definir') document.getElementById('wAddress').value = c.address;
}).catch(function(){});
</script>
</body>
</html>
