<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Invoicing | <%- title %></title>
    <link rel="icon" type="image/png" href="images/invoicing-logo-simple.png" />

    <link href="assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
        integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />

    <link href="assets/css/sb-admin-2.min.css" rel="stylesheet">
    <link href="assets/vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet">
    <link href="assets/css/custom.css" rel="stylesheet" />

    <style>
        body {
            font-size: 0.85rem !important;
        }

        table {
            font-size: 0.8rem !important;
        }

        table tr th,
        table tr td {
            padding: 0.3rem !important;
            vertical-align: middle !important;
        }

        table tr td:last-child {
            text-align: center !important;
            white-space: nowrap;
        }

        .badge-role {
            font-size: .72rem;
            padding: .35rem .55rem;
            border-radius: 999px;
            font-weight: 800;
        }

        .badge-status {
            font-size: .72rem;
            padding: .35rem .55rem;
            border-radius: 999px;
            font-weight: 800;
        }

        .permissions-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: .5rem .75rem;
        }

        .permission-item {
            display: flex;
            align-items: center;
            gap: .55rem;
            background: #f8f9fc;
            border: 1px solid #e3e6f0;
            border-radius: 10px;
            padding: .55rem .7rem;
            min-height: 44px;
        }

        .permission-item input {
            transform: scale(1.05);
        }

        .table-user-name {
            font-weight: 800;
            color: #2e2e2e;
        }

        .table-user-email {
            font-size: .75rem;
            color: #6c757d;
        }

        .modal-section-title {
            font-size: .78rem;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #858796;
            font-weight: 800;
            margin-bottom: .75rem;
        }

        .permissions-box {
            border: 1px solid #e3e6f0;
            border-radius: 12px;
            padding: .85rem;
            background: #fff;
        }

        @media (max-width: 768px) {
            #usersMobileList .u-card {
                border: 1px solid rgba(0, 0, 0, .08);
                border-radius: 14px;
                padding: 12px;
                background: #fff;
                box-shadow: 0 2px 12px rgba(0, 0, 0, .04);
                margin-bottom: 10px;
            }

            #usersMobileList .u-top {
                display: flex;
                justify-content: space-between;
                gap: 10px;
                margin-bottom: 8px;
            }

            #usersMobileList .u-name {
                font-weight: 900;
                font-size: .95rem;
                color: #2d3748;
                line-height: 1.2;
            }

            #usersMobileList .u-email {
                font-size: .78rem;
                color: #718096;
                word-break: break-word;
            }

            #usersMobileList .u-meta {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                margin: 10px 0;
            }

            #usersMobileList .u-pill {
                font-size: .78rem;
                padding: 4px 10px;
                border-radius: 999px;
                background: #f1f5f9;
                color: #334155;
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

            #usersMobileList .u-actions {
                display: flex;
                gap: 8px;
                margin-top: 10px;
            }

            #usersMobileList .u-actions .btn {
                flex: 1;
                border-radius: 12px;
                padding: 10px 12px;
                font-weight: 900;
            }

            #btn-open-user-modal {
                border-radius: 12px;
                padding: 10px 12px;
                font-weight: 900;
            }

            #createUserModal .modal-dialog,
            #updateUserModal .modal-dialog {
                margin: 0;
                max-width: 100%;
                height: 100%;
            }

            #createUserModal .modal-content,
            #updateUserModal .modal-content {
                height: 100vh;
                border: 0;
                border-radius: 0;
            }

            #createUserModal .modal-header,
            #updateUserModal .modal-header {
                position: sticky;
                top: 0;
                z-index: 10;
                background: #fff;
                border-bottom: 1px solid rgba(0, 0, 0, .08);
            }

            #createUserModal .modal-body,
            #updateUserModal .modal-body {
                overflow-y: auto;
                -webkit-overflow-scrolling: touch;
            }

            #createUserModal .modal-footer,
            #updateUserModal .modal-footer {
                position: sticky;
                bottom: 0;
                z-index: 10;
                background: #fff;
                border-top: 1px solid rgba(0, 0, 0, .08);
            }

            #createUserModal .form-control,
            #updateUserModal .form-control {
                min-height: 48px;
                border-radius: 12px;
                font-weight: 700;
            }

            .permissions-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body id="page-top">
    <div id="wrapper">
        <%- include('partials/sidebar') %>

        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">

                <%- include('partials/topbar') %>

                <div class="container-fluid">
                    <div class="d-sm-flex align-items-center justify-content-between mb-3">
                        <h1 class="h3 mb-2 text-gray-800" style="font-size: 1.2rem;">Utilizadores</h1>
                        <button type="button" class="btn btn-primary btn-sm" id="btn-open-user-modal">
                            <i class="fa-solid fa-user-plus"></i> Novo Utilizador
                        </button>
                    </div>

                    <div class="card shadow mb-4">
                        <div class="card-body">
                            <!-- MOBILE -->
                            <div id="usersMobileList" class="d-md-none"></div>

                            <!-- DESKTOP -->
                            <div class="table-responsive d-none d-md-block">
                                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                                    <thead>
                                        <tr class="bg-secondary text-white">
                                            <th>Utilizador</th>
                                            <th>Contacto</th>
                                            <th class="text-center">Papel</th>
                                            <th class="text-center">Estado</th>
                                            <th class="text-center">Permissões</th>
                                            <th class="text-center">Acções</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                    <tfoot></tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <%- include('partials/copyright') %>
            </div>
        </div>
    </div>

    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

    <!-- CREATE USER -->
    <div class="modal fade" id="createUserModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title">
                        <strong><i class="fa-solid fa-user-plus"></i> Adicionar Utilizador</strong>
                    </h6>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <form id="create-user-form">
                    <div class="modal-body">
                        <div class="modal-section-title">Dados do utilizador</div>
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>Nome</label>
                                <input type="text" class="form-control form-control-sm" id="user-name" placeholder="Nome completo" required>
                            </div>

                            <div class="form-group col-md-6">
                                <label>E-mail</label>
                                <input type="email" class="form-control form-control-sm" id="user-email" placeholder="email@empresa.com" required>
                            </div>

                            <div class="form-group col-md-6">
                                <label>Contacto</label>
                                <input type="text" class="form-control form-control-sm" id="user-contact" placeholder="84xxxxxxx">
                            </div>

                            <div class="form-group col-md-6">
                                <label>Papel</label>
                                <select class="form-control form-control-sm" id="user-role">
                                    <option value="USER" selected>Utilizador</option>
                                    <option value="ADMIN">Administrador</option>
                                </select>
                            </div>
                        </div>

                        <div class="modal-section-title">Permissões de acesso</div>
                        <div class="permissions-box">
                            <div class="mb-2">
                                <button type="button" class="btn btn-outline-primary btn-sm mr-2" id="btn-check-all-create">
                                    <i class="fa-solid fa-check-double"></i> Marcar tudo
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-uncheck-all-create">
                                    <i class="fa-solid fa-xmark"></i> Limpar
                                </button>
                            </div>

                            <div class="permissions-grid">
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="dashboard" checked> Dashboard</label>
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="sales" checked> Vendas</label>
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="stock" checked> Stock</label>
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="products" checked> Produtos</label>
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="invoicing" checked> Facturação</label>
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="customers" checked> Clientes</label>
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="suppliers" checked> Fornecedores</label>
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="reports" checked> Relatórios</label>
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="settings" checked> Configurações</label>
                                <label class="permission-item"><input type="checkbox" class="perm-create" value="users" checked> Utilizadores</label>
                            </div>

                            <small class="text-muted d-block mt-2">
                                Administradores terão acesso total. Estas permissões são mais úteis para utilizadores normais.
                            </small>
                        </div>
                    </div>
                </form>

                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" type="button" data-dismiss="modal">Fechar</button>
                    <button id="btn-create-user" class="btn btn-primary btn-sm">Salvar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- UPDATE USER -->
    <div class="modal fade" id="updateUserModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title">
                        <strong><i class="fa-solid fa-pen-to-square"></i> Actualizar Utilizador</strong>
                    </h6>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <form id="update-user-form">
                    <input type="hidden" id="update-user-id">

                    <div class="modal-body">
                        <div class="modal-section-title">Dados do utilizador</div>
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>Nome</label>
                                <input type="text" class="form-control form-control-sm" id="user-name-update" placeholder="Nome completo" required>
                            </div>

                            <div class="form-group col-md-6">
                                <label>E-mail</label>
                                <input type="email" class="form-control form-control-sm" id="user-email-update" placeholder="email@empresa.com" required>
                            </div>

                            <div class="form-group col-md-6">
                                <label>Contacto</label>
                                <input type="text" class="form-control form-control-sm" id="user-contact-update" placeholder="84xxxxxxx">
                            </div>

                            <div class="form-group col-md-3">
                                <label>Papel</label>
                                <select class="form-control form-control-sm" id="user-role-update">
                                    <option value="USER">Utilizador</option>
                                    <option value="ADMIN">Administrador</option>
                                </select>
                            </div>

                            <div class="form-group col-md-3">
                                <label>Estado</label>
                                <select class="form-control form-control-sm" id="user-status-update">
                                    <option value="active">Activo</option>
                                    <option value="blocked">Bloqueado</option>
                                </select>
                            </div>
                        </div>

                        <div class="modal-section-title">Permissões de acesso</div>
                        <div class="permissions-box">
                            <div class="mb-2">
                                <button type="button" class="btn btn-outline-primary btn-sm mr-2" id="btn-check-all-update">
                                    <i class="fa-solid fa-check-double"></i> Marcar tudo
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-uncheck-all-update">
                                    <i class="fa-solid fa-xmark"></i> Limpar
                                </button>
                            </div>

                            <div class="permissions-grid">
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="dashboard"> Dashboard</label>
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="sales"> Vendas</label>
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="stock"> Stock</label>
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="products"> Produtos</label>
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="invoicing"> Facturação</label>
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="customers"> Clientes</label>
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="suppliers"> Fornecedores</label>
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="reports"> Relatórios</label>
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="settings"> Configurações</label>
                                <label class="permission-item"><input type="checkbox" class="perm-update" value="users"> Utilizadores</label>
                            </div>
                        </div>
                    </div>
                </form>

                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" type="button" data-dismiss="modal">Fechar</button>
                    <button id="btn-update-user" class="btn btn-primary btn-sm">Actualizar</button>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script src="assets/vendor/datatables/jquery.dataTables.min.js"></script>
    <script src="assets/vendor/datatables/dataTables.bootstrap4.min.js"></script>
    <script src="assets/js/users.js"></script>
</body>

</html>