<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Invoicing | <%- title %></title>
    <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png" />
    <!-- Custom fonts for this template -->
    <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link
        href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
        rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
        integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- Custom styles for this template -->
    <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet">

    <!-- Custom styles for this page -->
    <link href="/assets/vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet">
    <link href="/assets/css/custom.css" rel="stylesheet" />

    <style>
        body {
            font-size: 0.85rem !important;
        }

        table {
            font-size: 0.8rem !important;
        }

        table tr th,
        table tr td {
            padding: 0.3rem !important;
            vertical-align: middle !important;
        }

        table tr td:last-child,
        table tr td:nth-last-child(2) {
            text-align: center !important;
        }

        table tr td:last-child {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
        }

        /* =========================
   PRODUCTS - Mobile Cards
   ========================= */
        #productsMobileList .p-card {
            border: 1px solid rgba(0, 0, 0, .08);
            border-radius: 14px;
            padding: 12px;
            background: #fff;
            box-shadow: 0 2px 12px rgba(0, 0, 0, .04);
            margin-bottom: 10px;
        }

        #productsMobileList .p-top {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 8px;
        }

        #productsMobileList .p-name {
            font-weight: 900;
            font-size: .95rem;
            color: #2d3748;
            line-height: 1.2;
        }

        #productsMobileList .p-sku {
            font-size: .78rem;
            color: #718096;
            white-space: nowrap;
        }

        #productsMobileList .p-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 10px;
        }

        #productsMobileList .p-pill {
            font-size: .78rem;
            padding: 4px 10px;
            border-radius: 999px;
            background: #f1f5f9;
            color: #334155;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        #productsMobileList .p-pill strong {
            font-weight: 900;
        }

        #productsMobileList .p-actions {
            display: flex;
            gap: 8px;
        }

        #productsMobileList .p-actions .btn {
            flex: 1;
            border-radius: 12px;
            padding: 10px 12px;
            font-weight: 900;
        }

        @media (max-width:768px) {
            #btnProductsMobileLoadMore {
                border-radius: 12px;
                padding: 10px 12px;
                font-weight: 900;
            }

            /* header botão "Adicionar Produto" mais confortável */
            #btn-create-product {
                border-radius: 12px;
                padding: 10px 12px;
                font-weight: 900;
            }
        }

        /* =========================
   MODALS FULLSCREEN (mobile)
   ========================= */
        @media (max-width: 768px) {

            #productModal .modal-dialog,
            #updateProductModal .modal-dialog,
            #stockModal .modal-dialog {
                margin: 0;
                max-width: 100%;
                height: 100%;
            }

            #productModal .modal-content,
            #updateProductModal .modal-content,
            #stockModal .modal-content {
                height: 100vh;
                border: 0;
                border-radius: 0;
            }

            #productModal .modal-header,
            #updateProductModal .modal-header,
            #stockModal .modal-header {
                position: sticky;
                top: 0;
                z-index: 10;
                background: #fff;
                border-bottom: 1px solid rgba(0, 0, 0, .08);
            }

            #productModal .modal-body,
            #updateProductModal .modal-body,
            #stockModal .modal-body {
                overflow-y: auto;
                -webkit-overflow-scrolling: touch;
            }

            #productModal .modal-footer,
            #updateProductModal .modal-footer,
            #stockModal .modal-footer {
                position: sticky;
                bottom: 0;
                z-index: 10;
                background: #fff;
                border-top: 1px solid rgba(0, 0, 0, .08);
            }

            /* inputs maiores */
            #productModal .form-control,
            #updateProductModal .form-control,
            #stockModal .form-control {
                height: 48px;
                border-radius: 12px;
                font-weight: 700;
            }
        }
    </style>
</head>

<body id="page-top">

    <!-- Page Wrapper -->
    <div id="wrapper">
        <%- include('partials/sidebar') %>

            <!-- Content Wrapper -->
            <div id="content-wrapper" class="d-flex flex-column">

                <!-- Main Content -->
                <div id="content">

                    <%- include('partials/topbar') %>
                        
                            <!-- Begin Page Content -->
                            <div class="container-fluid">

                                <!-- Page Heading -->
                                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                                    <h5 class="mb-0 text-gray-800">Produtos</h5>
                                    <button class="btn btn-primary btn-sm" id="btn-create-product" type="button"
                                        data-toggle="modal" data-target="#productModal">
                                        <i class="fas fa-plus fa-sm text-white-50"></i> Adicionar Produto
                                    </button>

                                </div>

                                <!-- DataTales Example -->
                                <div class="card shadow mb-4">
                                    <div class="card-body">
                                        <!-- MOBILE: cards -->
                                        <div id="productsMobileList" class="d-md-none"></div>

                                        <!-- DESKTOP: tabela -->
                                        <div class="table-responsive d-none d-md-block">
                                            <table class="table table-bordered" id="dataTable" width="100%"
                                                cellspacing="0">
                                                <thead>
                                                    <tr class="bg-secondary text-white">
                                                        <th>Produto</th>
                                                        <th class="text-center">Código</th>
                                                        <th class="text-center">Unid.</th>
                                                        <th class="text-center">Preço</th>
                                                        <th class="text-center">Stock</th>
                                                        <th class="text-center">Mín.</th>
                                                        <th class="text-center">Estado</th>
                                                        <th class="text-center">Acções</th>
                                                    </tr>
                                                </thead>
                                                <tbody>

                                                </tbody>
                                                <tfoot>
                                                </tfoot>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <!-- /.container-fluid -->

                <!-- End of Main Content -->

                <%- include('partials/copyright') %>

            </div>
            <!-- End of Content Wrapper -->

    </div>
    <!-- End of Page Wrapper -->

    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

    <!-- Confirmation Modal-->
    <div class="modal fade" id="productModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
        aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalLabel"><strong><i class="fa-solid fa-pen-to-square"></i>
                            Adicionar Produto</strong></h6>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <form id="add-product-form">
                    <div class="modal-body">
                        <div class="row">
                            <div class="form-group col-md-12">
                                <label>Tipo</label>
                                <select class="form-control form-control-sm" id="add-product-type">
                                    <option value="product">Produto (com stock)</option>
                                    <option value="service">Serviço (sem stock)</option>
                                </select>
                                <small class="text-muted">Serviços não controlam stock (ex: consultoria, transporte, mão-de-obra).</small>
                            </div>

                            <div class="form-group col-md-8">
                                <label>Nome</label>
                                <input type="text" class="form-control form-control-sm" id="add-product-name"
                                    placeholder="Ex: Paracetamol" required>
                            </div>

                            <div class="form-group col-md-4">
                                <label>SKU (opcional)</label>
                                <input type="text" class="form-control form-control-sm" id="add-product-sku"
                                    placeholder="Ex: PAR-500">
                            </div>

                            <div class="form-group col-md-4 add-product-stock-field">
                                <label>Unidade</label>
                                <select class="form-control form-control-sm" id="add-product-unit">
                                    <option value="un">Unidade (un)</option>
                                    <option value="kg">Quilo (kg)</option>
                                    <option value="lt">Litro (lt)</option>
                                    <option value="cx">Caixa (cx)</option>
                                </select>
                            </div>

                            <div class="form-group col-md-4">
                                <label>Preço de Venda</label>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm"
                                    id="add-product-price" placeholder="0.00" required>
                            </div>

                            <div class="form-group col-md-4">
                                <label>Preço de Compra</label>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm"
                                    id="add-product-cost" placeholder="0.00">
                                <small class="text-muted">Custo de aquisição (para cálculo de margem).</small>
                            </div>

                            <div class="form-group col-md-4 add-product-stock-field">
                                <label>Stock Inicial</label>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm"
                                    id="add-product-stock" value="0">
                            </div>

                            <div class=”form-group col-md-4 add-product-stock-field”>
                                <label>Stock Mínimo</label>
                                <input type=”number” step=”0.01” min=”0” class=”form-control form-control-sm”
                                    id=”add-product-min” value=”0”>
                                <small class=”text-muted”>Quando o stock atingir este valor, aparece “Baixo”.</small>
                            </div>

                            <div class=”form-group col-md-4 add-product-stock-field”>
                                <label>Prazo de Validade</label>
                                <input type=”date” class=”form-control form-control-sm” id=”add-product-expiry”>
                            </div>

                            <div class=”form-group col-md-4 add-product-stock-field”>
                                <label>Alertar N dias antes</label>
                                <input type=”number” min=”1” class=”form-control form-control-sm”
                                    id=”add-product-expiry-days” value=”30”>
                                <small class=”text-muted”>Dias antes do vencimento para gerar alerta.</small>
                            </div>
                        </div>
                    </div>
                </form>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" type="button" data-dismiss="modal">Fechar</button>
                    <button id="btn-add-product" class="btn btn-primary btn-sm">Adicionar</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="updateProductModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
        aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalLabel"><strong><i class="fa-solid fa-pen-to-square"></i>
                            Actualizar Produto</strong></h6>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <form id="update-product-form">
                    <div class="modal-body">
                        <div class="row">

                            <div class="form-group col-md-12">
                                <label>Tipo</label>
                                <select class="form-control form-control-sm" id="update-product-type">
                                    <option value="product">Produto (com stock)</option>
                                    <option value="service">Serviço (sem stock)</option>
                                </select>
                            </div>

                            <div class="form-group col-md-8">
                                <label>Nome</label>
                                <input type="text" class="form-control form-control-sm" id="update-product-name"
                                    placeholder="Nome do Produto" required>
                            </div>

                            <div class="form-group col-md-4">
                                <label>SKU (opcional)</label>
                                <input type="text" class="form-control form-control-sm" id="update-product-sku"
                                    placeholder="Ex: PAR-500">
                            </div>

                            <div class="form-group col-md-4">
                                <label>Unidade</label>
                                <select class="form-control form-control-sm" id="update-product-unit">
                                    <option value="un">Unidade (un)</option>
                                    <option value="kg">Quilo (kg)</option>
                                    <option value="lt">Litro (lt)</option>
                                    <option value="cx">Caixa (cx)</option>
                                </select>
                            </div>

                            <div class="form-group col-md-4">
                                <label>Preço de Venda</label>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm"
                                    id="update-product-price" placeholder="0.00" required>
                                <small class="text-muted">Apenas administradores.</small>
                            </div>

                            <div class="form-group col-md-4">
                                <label>Preço de Compra</label>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm"
                                    id="update-product-cost" placeholder="0.00">
                                <small class="text-muted">Apenas administradores.</small>
                            </div>

                            <div class="form-group col-md-4 update-product-stock-field">
                                <label>Stock Mínimo</label>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm"
                                    id="update-product-min" value="0">
                            </div>

                            <div class="form-group col-md-4 update-product-stock-field">
                                <label>Prazo de Validade</label>
                                <input type="date" class="form-control form-control-sm" id="update-product-expiry">
                            </div>

                            <div class="form-group col-md-4 update-product-stock-field">
                                <label>Alertar N dias antes</label>
                                <input type="number" min="1" class="form-control form-control-sm"
                                    id="update-product-expiry-days" value="30">
                            </div>

                            <div class="form-group col-md-4">
                                <label>Estado</label>
                                <select class="form-control form-control-sm" id="update-product-active">
                                    <option value="true">Ativo</option>
                                    <option value="false">Inativo</option>
                                </select>
                                <small class="text-muted">Produtos inativos ficam escondidos.</small>
                            </div>

                            <div class="form-group col-md-12">
                                <div class="alert alert-light border mb-0 text-center">
                                    <small class="text-warning">
                                        <strong>Dica:</strong> Para alterar <strong>stock</strong>, use o botão de
                                        caixas (Ajustar Stock).
                                    </small>
                                </div>
                            </div>

                        </div>
                    </div>
                </form>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" type="button" data-dismiss="modal">Cancelar</button>
                    <button id="btn-update-product" class="btn btn-primary btn-sm">Actualizar</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="stockModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title"><strong><i class="fa-solid fa-boxes-stacked mr-2"></i>Ajustar Stock</strong>
                    </h6>
                    <button class="close" type="button" data-dismiss="modal"><span>×</span></button>
                </div>

                <form id="stock-form">
                    <input type="hidden" id="stock-product-id" />

                    <div class="modal-body">
                        <div class="mb-2">
                            <div><strong id="stock-product-name"></strong></div>
                            <small class="text-muted">Stock atual: <span id="stock-current"></span></small>
                        </div>

                        <div class="form-group">
                            <label>Tipo</label>
                            <select class="form-control form-control-sm" id="stock-type" required>
                                <option value="IN">Entrada</option>
                                <option value="OUT">Saída</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Quantidade</label>
                            <input type="number" min="0.000001" step="0.01" class="form-control form-control-sm"
                                id="stock-qty" required />
                        </div>

                        <div class="form-group" id="stock-cost-wrapper">
                            <label>Preço de Compra Unitário</label>
                            <input type="number" min="0" step="0.01" class="form-control form-control-sm"
                                id="stock-cost" placeholder="0.00" />
                            <small class="text-muted">Custo de aquisição deste lote (actualiza o custo médio do produto).</small>
                        </div>

                        <div class="form-group">
                            <label>Motivo</label>
                            <select name="stock-reason" class="form-control form-control-sm" id="stock-reason">
                                
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Nota (opcional)</label>
                            <input type="text" class="form-control form-control-sm" id="stock-note" />
                        </div>
                    </div>
                </form>

                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" type="button" data-dismiss="modal">Cancelar</button>
                    <button class="btn btn-primary btn-sm" type="button" id="btn-save-stock">Salvar</button>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

        <!-- Page level plugins -->
        <script src="/assets/vendor/datatables/jquery.dataTables.min.js"></script>
        <script src="/assets/vendor/datatables/dataTables.bootstrap4.min.js"></script>

        <script src="/assets/js/products.js"></script>
</body>

</html>