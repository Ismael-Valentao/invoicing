<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>
  <title>Invoicing — <%- title %></title>
  <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png"/>
  <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,400,600,700,800" rel="stylesheet"/>
  <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet"/>
  <link href="/assets/css/custom.css" rel="stylesheet"/>
</head>
<body id="page-top">
<div id="wrapper">

  <%- include('../partials/admin-sidebar') %>

  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      <%- include('../partials/topbar') %>

      <div class="container-fluid py-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
          <h4 class="font-weight-bold text-gray-800 mb-0">
            <i class="fas fa-shield-alt text-danger mr-2"></i>Painel de Administração
          </h4>
          <span class="badge badge-pill badge-danger px-3 py-2" style="font-size:.8rem;">SUPERADMIN</span>
        </div>

        <!-- KPI Cards -->
        <div class="row mb-4" id="kpiCards">
          <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
              <div class="card-body">
                <div class="row no-gutters align-items-center">
                  <div class="col mr-2">
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total de Empresas</div>
                    <div class="h4 mb-0 font-weight-bold text-gray-800" id="statTotalCompanies">—</div>
                  </div>
                  <div class="col-auto"><i class="fas fa-building fa-2x text-gray-300"></i></div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
              <div class="card-body">
                <div class="row no-gutters align-items-center">
                  <div class="col mr-2">
                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Subscrições Activas</div>
                    <div class="h4 mb-0 font-weight-bold text-gray-800" id="statActiveSubs">—</div>
                  </div>
                  <div class="col-auto"><i class="fas fa-star fa-2x text-gray-300"></i></div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
              <div class="card-body">
                <div class="row no-gutters align-items-center">
                  <div class="col mr-2">
                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Expiram em 7 dias</div>
                    <div class="h4 mb-0 font-weight-bold text-gray-800" id="statExpiringSoon">—</div>
                  </div>
                  <div class="col-auto"><i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i></div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
              <div class="card-body">
                <div class="row no-gutters align-items-center">
                  <div class="col mr-2">
                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Receita Potencial / mês</div>
                    <div class="h4 mb-0 font-weight-bold text-gray-800" id="statRevenue">—</div>
                  </div>
                  <div class="col-auto"><i class="fas fa-coins fa-2x text-gray-300"></i></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="row">
          <!-- Distribuição de planos -->
          <div class="col-xl-4 col-lg-5 mb-4">
            <div class="card shadow h-100">
              <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Distribuição de Planos</h6>
              </div>
              <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <canvas id="planPieChart" style="max-width:220px; max-height:220px;"></canvas>
                <div id="planLegend" class="mt-3 w-100"></div>
              </div>
            </div>
          </div>

          <!-- Últimas empresas -->
          <div class="col-xl-8 col-lg-7 mb-4">
            <div class="card shadow h-100">
              <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Empresas Recentes</h6>
                <a href="/admin/companies" class="btn btn-sm btn-outline-primary">Ver todas</a>
              </div>
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-hover mb-0" id="recentCompaniesTable">
                    <thead class="thead-light">
                      <tr>
                        <th>Empresa</th>
                        <th>Email</th>
                        <th>Registada em</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody id="recentCompaniesTbody">
                      <tr><td colspan="4" class="text-center text-muted py-3">A carregar...</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Dados de Pagamento -->
        <div class="row">
          <div class="col-12 mb-4">
            <div class="card shadow">
              <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">
                  <i class="fas fa-money-bill-wave mr-2"></i>Dados de Pagamento
                </h6>
              </div>
              <div class="card-body">
                <p class="text-muted small mb-3">Estes dados são mostrados aos utilizadores na página de upgrade para efectuarem o pagamento.</p>
                <form id="paymentSettingsForm">
                  <div class="row">
                    <div class="col-md-4 mb-3">
                      <label class="small font-weight-bold">Número M-Pesa</label>
                      <input type="text" class="form-control form-control-sm" id="ps_mpesa" placeholder="Ex: 84 123 4567"/>
                    </div>
                    <div class="col-md-4 mb-3">
                      <label class="small font-weight-bold">Número E-mola</label>
                      <input type="text" class="form-control form-control-sm" id="ps_emola" placeholder="Ex: 86 123 4567"/>
                    </div>
                  </div>
                  <div class="row">
                    <div class="col-md-4 mb-3">
                      <label class="small font-weight-bold">Banco</label>
                      <input type="text" class="form-control form-control-sm" id="ps_bankName" placeholder="Ex: BCI"/>
                    </div>
                    <div class="col-md-4 mb-3">
                      <label class="small font-weight-bold">Titular</label>
                      <input type="text" class="form-control form-control-sm" id="ps_bankHolder" placeholder="Ex: Bitiray, Lda"/>
                    </div>
                    <div class="col-md-4 mb-3">
                      <label class="small font-weight-bold">NIB</label>
                      <input type="text" class="form-control form-control-sm" id="ps_bankNIB" placeholder="Ex: 0008 0000 XXXXXXXXXX 53"/>
                    </div>
                  </div>
                  <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fas fa-save mr-1"></i>Guardar
                  </button>
                  <span id="psMsg" class="ml-3 small"></span>
                </form>
              </div>
            </div>
          </div>
        </div>

        <!-- Subscrições a expirar em breve -->
        <div class="row">
          <div class="col-12 mb-4">
            <div class="card shadow">
              <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-warning">
                  <i class="fas fa-exclamation-triangle mr-2"></i>Subscrições a Expirar em 7 Dias
                </h6>
                <a href="/admin/subscriptions?status=active" class="btn btn-sm btn-outline-warning">Ver todas</a>
              </div>
              <div class="card-body p-0" id="expiringSoonList">
                <p class="text-muted text-center py-3">A carregar...</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
    <%- include('../partials/footer') %>
  </div>
</div>

<script src="/assets/vendor/jquery/jquery.min.js"></script>
<script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/assets/vendor/chart.js/Chart.min.js"></script>
<script src="/assets/js/sb-admin-2.min.js"></script>
<script>
const PLAN_COLORS = { FREE: '#858796', BASIC: '#4e73df', PREMIUM: '#1cc88a' };

async function loadStats() {
  try {
    const res = await fetch('/api/admin/stats');
    const data = await res.json();
    if (!data.success) return;
    const s = data.stats;

    document.getElementById('statTotalCompanies').textContent = s.totalCompanies;
    document.getElementById('statActiveSubs').textContent = s.activeSubs;
    document.getElementById('statExpiringSoon').textContent = s.expiringSoon;
    document.getElementById('statRevenue').textContent = (s.potentialRevenue || 0).toLocaleString('pt-MZ') + ' MZN';

    // Gráfico de pizza
    const labels = s.planDistribution.map(p => p._id);
    const values = s.planDistribution.map(p => p.count);
    const colors = labels.map(l => PLAN_COLORS[l] || '#aaa');
    new Chart(document.getElementById('planPieChart'), {
      type: 'doughnut',
      data: { labels, datasets: [{ data: values, backgroundColor: colors, hoverBackgroundColor: colors }] },
      options: { maintainAspectRatio: false, legend: { display: false } }
    });
    document.getElementById('planLegend').innerHTML = labels.map((l, i) =>
      `<div class="d-flex justify-content-between small mb-1">
        <span><i class="fas fa-circle mr-1" style="color:${colors[i]}"></i>${l}</span>
        <strong>${values[i]}</strong>
      </div>`
    ).join('');

    // Empresas recentes
    const tbody = document.getElementById('recentCompaniesTbody');
    tbody.innerHTML = s.recentCompanies.map(c =>
      `<tr>
        <td class="font-weight-bold">${c.name}</td>
        <td>${c.email}</td>
        <td>${new Date(c.createdAt).toLocaleDateString('pt-PT')}</td>
        <td><a href="/admin/companies" class="btn btn-xs btn-outline-primary" style="font-size:.75rem; padding:2px 8px;">Ver</a></td>
      </tr>`
    ).join('') || '<tr><td colspan="4" class="text-muted text-center">Nenhuma empresa.</td></tr>';

  } catch(e) { console.error(e); }
}

async function loadExpiringSoon() {
  try {
    const res = await fetch('/api/admin/subscriptions?status=active');
    const data = await res.json();
    if (!data.success) return;
    const now = Date.now();
    const in7 = now + 7 * 86400000;
    const soon = data.subscriptions.filter(s => {
      const exp = new Date(s.expiresAt).getTime();
      return exp >= now && exp <= in7;
    });
    const el = document.getElementById('expiringSoonList');
    if (!soon.length) {
      el.innerHTML = '<p class="text-success text-center py-3"><i class="fas fa-check-circle mr-2"></i>Nenhuma subscrição a expirar nos próximos 7 dias.</p>';
      return;
    }
    el.innerHTML = `<div class="table-responsive"><table class="table mb-0">
      <thead class="thead-light"><tr><th>Empresa</th><th>Plano</th><th>Expira em</th><th>Dias</th><th></th></tr></thead>
      <tbody>${soon.map(s => `
        <tr>
          <td><strong>${s.companyName}</strong><br><small class="text-muted">${s.companyEmail}</small></td>
          <td><span class="badge badge-primary">${s.planLabel}</span></td>
          <td>${new Date(s.expiresAt).toLocaleDateString('pt-PT')}</td>
          <td><span class="badge badge-warning">${s.daysLeft}d</span></td>
          <td>
            <button class="btn btn-success btn-sm" onclick="quickActivate('${s.companyId}','${s.plan}')">
              <i class="fas fa-check mr-1"></i>Renovar
            </button>
          </td>
        </tr>`).join('')}
      </tbody></table></div>`;
  } catch(e) {}
}

function quickActivate(companyId, plan) {
  if (!confirm('Renovar subscrição por mais 30 dias?')) return;
  fetch('/api/admin/subscriptions/activate', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ companyId, plan, months: 1 })
  }).then(r => r.json()).then(d => {
    alert(d.message);
    if (d.success) loadExpiringSoon();
  });
}

loadStats();
loadExpiringSoon();

// ── Dados de pagamento ────────────────────────────────────────────────────────
(async function loadPaymentSettings() {
  try {
    const res = await fetch('/api/admin/payment-settings');
    const data = await res.json();
    if (!data.success) return;
    const s = data.settings;
    document.getElementById('ps_mpesa').value      = s.mpesa      || '';
    document.getElementById('ps_emola').value      = s.emola      || '';
    document.getElementById('ps_bankName').value   = s.bankName   || '';
    document.getElementById('ps_bankHolder').value = s.bankHolder || '';
    document.getElementById('ps_bankNIB').value    = s.bankNIB    || '';
  } catch(e) {}
})();

document.getElementById('paymentSettingsForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const msg = document.getElementById('psMsg');
  const body = {
    mpesa:      document.getElementById('ps_mpesa').value.trim(),
    emola:      document.getElementById('ps_emola').value.trim(),
    bankName:   document.getElementById('ps_bankName').value.trim(),
    bankHolder: document.getElementById('ps_bankHolder').value.trim(),
    bankNIB:    document.getElementById('ps_bankNIB').value.trim(),
  };
  try {
    const res = await fetch('/api/admin/payment-settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();
    msg.style.color = data.success ? '#1cc88a' : '#e74a3b';
    msg.textContent = data.message;
    setTimeout(() => { msg.textContent = ''; }, 3000);
  } catch(e) {
    msg.style.color = '#e74a3b';
    msg.textContent = 'Erro de ligação.';
  }
});
</script>
</body>
</html>
