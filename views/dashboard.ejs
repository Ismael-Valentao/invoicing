<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />
    <meta name="description" content="" />
    <meta name="author" content="" />

    <title>Invoicing - <%- title %></title>
<link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png"/>
    <!-- Custom fonts for this template-->
    <link
      href="/assets/vendor/fontawesome-free/css/all.min.css"
      rel="stylesheet"
      type="text/css"
    />
    <link
      href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <!-- Custom styles for this template-->
    <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet" />
    <link href="/assets/css/custom.css" rel="stylesheet" />
  </head>

  <body id="page-top">
    <!-- Page Wrapper -->
    <div id="wrapper">
        
      <%- include ('partials/sidebar') %>

      <!-- Content Wrapper -->
      <div id="content-wrapper" class="d-flex flex-column">
        <!-- Main Content -->
        <div id="content">
          <!-- Topbar -->
          <%- include ('partials/topbar') %>
          <!-- End of Topbar -->
          <!-- Begin Page Content -->
          <div class="container-fluid">

            <!-- Banner de subscrição expirada -->
            <div id="subExpiredBanner" style="display:none;" class="alert alert-danger d-flex align-items-center justify-content-between mb-3">
              <span><i class="fas fa-lock mr-2"></i><strong>Subscrição expirada.</strong> Renova o teu plano para continuar a criar documentos.</span>
              <a href="/upgrade" class="btn btn-danger btn-sm ml-3">Renovar agora</a>
            </div>

            <!-- Banner de expiração próxima -->
            <div id="subWarningBanner" style="display:none;" class="alert alert-warning d-flex align-items-center justify-content-between mb-3">
              <span><i class="fas fa-exclamation-triangle mr-2"></i>A tua subscrição expira em <strong id="subDaysLeft"></strong> dias.</span>
              <a href="/upgrade" class="btn btn-warning btn-sm ml-3">Renovar</a>
            </div>

            <!-- Saudação contextual -->
            <div id="greetingCard" class="card shadow-sm mb-4 border-left-primary" style="display:none;">
              <div class="card-body py-3">
                <div class="d-flex align-items-center">
                  <div class="mr-3">
                    <i id="greetingIcon" class="fas fa-hand-sparkles fa-2x text-primary"></i>
                  </div>
                  <div class="flex-grow-1">
                    <h5 class="mb-1 font-weight-bold text-gray-800" id="greetingTitle"></h5>
                    <div class="text-xs text-gray-500 mb-1" id="greetingDate"></div>
                    <div class="text-sm text-gray-700" id="greetingMessage"></div>
                  </div>
                  <button type="button" class="close ml-2" aria-label="Fechar" onclick="document.getElementById('greetingCard').style.display='none'">
                    <span aria-hidden="true">&times;</span>
                  </button>
                </div>
              </div>
            </div>

            <!-- Checklist de onboarding -->
            <%- include('partials/onboarding-checklist') %>

            <!-- Content Row -->
            <div class="row">
              <!-- Earnings (Monthly) Card Example -->
              <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100 py-2">
                  <div class="card-body">
                    <div class="row no-gutters align-items-center">
                      <div class="col mr-2">
                        <div
                          class="text-xs font-weight-bold text-primary text-uppercase mb-1"
                        >
                          Total Facturado
                        </div>
                        <div
                          class="h6 mb-0 font-weight-bold text-gray-800"
                          id="total-amount"
                        ></div>
                      </div>
                      <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Earnings (Monthly) Card Example -->
              <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-success shadow h-100 py-2">
                  <div class="card-body">
                    <div class="row no-gutters align-items-center">
                      <div class="col mr-2">
                        <div
                          class="text-xs font-weight-bold text-success text-uppercase mb-1"
                        >
                          Nº de Facturas
                        </div>
                        <div
                          class="h6 mb-0 font-weight-bold text-gray-800"
                          id="total-invoices"
                        ></div>
                      </div>
                      <div class="col-auto">
                        <i class="fas fa-calendar fa-2x text-gray-300"></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Earnings (Monthly) Card Example -->
              <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-info shadow h-100 py-2">
                  <div class="card-body">
                    <div class="row no-gutters align-items-center">
                      <div class="col mr-2">
                        <div
                          class="text-xs font-weight-bold text-info text-uppercase mb-1"
                        >
                          Última Factura
                        </div>
                        <div class="row no-gutters align-items-center">
                          <div class="col-auto">
                            <div
                              class="h6 mb-0 mr-3 font-weight-bold text-gray-800"
                              id="last-invoice"
                            ></div>
                          </div>
                        </div>
                      </div>
                      <div class="col-auto">
                        <i
                          class="fas fa-clipboard-list fa-2x text-gray-300"
                        ></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Pending Requests Card Example -->
              <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-warning shadow h-100 py-2">
                  <div class="card-body">
                    <div class="row no-gutters align-items-center">
                      <div class="col mr-2">
                        <div
                          class="text-xs font-weight-bold text-warning text-uppercase mb-1"
                        >
                          Facturas Pagas
                        </div>
                        <div
                          class="h6 mb-0 font-weight-bold text-gray-800"
                          id="paid-invoices"
                        ></div>
                      </div>
                      <div class="col-auto">
                        <i class="fas fa-comments fa-2x text-gray-300"></i>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Content Row -->

            <div class="row">
              <!-- Area Chart -->
              <div class="col-xl-8 col-lg-7">
                <div class="card shadow mb-4">
                  <!-- Card Header - Dropdown -->
                  <div
                    class="card-header py-3 d-flex flex-row align-items-center justify-content-between"
                  >
                    <h6 class="m-0 font-weight-bold text-primary">
                      Gráfico de Facturas
                    </h6>
                  </div>
                  <!-- Card Body -->
                  <div class="card-body">
                    <div class="chart-area">
                      <canvas id="myAreaChart"></canvas>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Pie Chart -->
              <div class="col-xl-4 col-lg-5">
                <div class="card shadow mb-4">
                  <!-- Card Header - Dropdown -->
                  <div
                    class="card-header py-3 d-flex flex-row align-items-center justify-content-between"
                  >
                    <h6 class="m-0 font-weight-bold text-primary">
                      Gráfico de Pagamentos
                    </h6>
                  </div>
                  <!-- Card Body -->
                  <div class="card-body">
                    <div class="chart-pie pt-4 pb-2">
                      <canvas id="myPieChart"></canvas>
                    </div>
                    <div class="mt-4 text-center small">
                      <span class="mr-2">
                        <i class="fas fa-circle text-primary"></i> Facturas
                        Pagas
                      </span>
                      <span class="mr-2">
                        <i class="fas fa-circle text-info"></i> Facturas Não
                        Pagas
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            </div>
          <!-- Card: Produtos a vencer -->
          <div id="expiryCard" class="card shadow mb-4" style="display:none;">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
              <h6 class="m-0 font-weight-bold text-warning">
                <i class="fas fa-clock mr-1"></i>Produtos a vencer prazo de validade
              </h6>
              <a href="/products" class="btn btn-outline-warning btn-sm">Ver todos</a>
            </div>
            <div class="card-body p-0" id="expiryBody"></div>
          </div>

          </div>
          <!-- /.container-fluid -->
        <!-- End of Main Content -->

        <%- include ('partials/copyright') %>
      </div>
      <!-- End of Content Wrapper -->
    </div>
    <!-- End of Page Wrapper -->

    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
      <i class="fas fa-angle-up"></i>
    </a>

    <!-- Logout Modal-->
    <div
      class="modal fade"
      id="logoutModal"
      tabindex="-1"
      role="dialog"
      aria-labelledby="exampleModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="exampleModalLabel">Ready to Leave?</h5>
            <button
              class="close"
              type="button"
              data-dismiss="modal"
              aria-label="Close"
            >
              <span aria-hidden="true">×</span>
            </button>
          </div>
          <div class="modal-body">
            Select "Logout" below if you are ready to end your current session.
          </div>
          <div class="modal-footer">
            <button
              class="btn btn-secondary"
              type="button"
              data-dismiss="modal"
            >
              Cancel
            </button>
            <a class="btn btn-primary" href="#">Logout</a>
          </div>
        </div>
      </div>
    </div>
    <%- include ('partials/footer') %>
    <!-- Page level plugins -->
    <script src="/assets/vendor/chart.js/Chart.min.js"></script>

    <!-- Page level custom scripts -->
    <script src="/assets/js/demo/chart-area-demo.js"></script>
    <script src="/assets/js/demo/chart-pie-demo.js"></script>
    <script src="/assets/js/dashboard.js"></script>
    <script>
    // Saudação contextual (mostra apenas uma vez por dia)
    (function loadGreeting() {
      try {
        const today = new Date().toISOString().slice(0, 10);
        const lastShown = localStorage.getItem('greetingShownDate');
        if (lastShown === today) return;

        fetch('/api/dashboard/greeting', { cache: 'no-store' })
          .then(r => r.ok ? r.json() : null)
          .then(data => {
            if (!data || !data.success || !data.greeting) return;
            const g = data.greeting;
            const card = document.getElementById('greetingCard');
            const icon = document.getElementById('greetingIcon');

            document.getElementById('greetingTitle').textContent = g.title;
            document.getElementById('greetingDate').textContent = g.date;
            document.getElementById('greetingMessage').textContent = g.message || '';

            // tom visual
            const toneMap = {
              primary: { border: 'border-left-primary', text: 'text-primary' },
              success: { border: 'border-left-success', text: 'text-success' },
              warning: { border: 'border-left-warning', text: 'text-warning' },
              danger:  { border: 'border-left-danger',  text: 'text-danger'  },
              info:    { border: 'border-left-info',    text: 'text-info'    },
            };
            const tone = toneMap[g.tone] || toneMap.primary;
            card.classList.remove('border-left-primary');
            card.classList.add(tone.border);
            icon.className = `fas ${g.icon || 'fa-hand-sparkles'} fa-2x ${tone.text}`;

            card.style.display = '';
            localStorage.setItem('greetingShownDate', today);
          })
          .catch(() => {});
      } catch (_) {}
    })();

    // Produtos a vencer prazo de validade
    (function loadExpiringProducts() {
      fetch('/api/dashboard/expiring-products', { cache: 'no-store' })
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (!data || !data.success) return;
          const items = [...(data.expired || []), ...(data.expiring || [])];
          if (!items.length) return;

          document.getElementById('expiryCard').style.display = '';
          document.getElementById('expiryBody').innerHTML = `
            <div class="table-responsive">
              <table class="table table-sm mb-0">
                <thead class="thead-light"><tr><th>Produto</th><th class="text-center">Validade</th><th class="text-center">Dias</th><th class="text-center">Stock</th></tr></thead>
                <tbody>${items.slice(0, 10).map(p => {
                  const expired = p.daysLeft <= 0;
                  return `<tr class="${expired ? 'table-danger' : ''}">
                    <td><strong>${p.description}</strong>${p.sku ? ' <small class="text-muted">(' + p.sku + ')</small>' : ''}</td>
                    <td class="text-center">${new Date(p.expiryDate).toLocaleDateString('pt-PT')}</td>
                    <td class="text-center"><span class="badge badge-${expired ? 'danger' : 'warning'}">${expired ? 'VENCIDO há ' + Math.abs(p.daysLeft) + 'd' : p.daysLeft + ' dias'}</span></td>
                    <td class="text-center">${p.stockQty}</td>
                  </tr>`;
                }).join('')}</tbody>
              </table>
            </div>`;
        })
        .catch(() => {});
    })();

    // Verificar estado da subscrição ao carregar o dashboard
    function checkSubscriptionStatus() {
      fetch('/api/subscriptions/my', { cache: 'no-store' })
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (!data || !data.success) return;
          const s = data.subscription;
          const days = typeof s.daysLeft === 'number' ? s.daysLeft : 0;
          const isExpired = s.status === 'expired' || days < 0;
          const showWarning = !isExpired && days >= 0 && days <= 7;
          document.getElementById('subExpiredBanner').style.display = isExpired ? 'flex' : 'none';
          document.getElementById('subWarningBanner').style.display = showWarning ? 'flex' : 'none';
          if (showWarning) {
            document.getElementById('subDaysLeft').textContent = days;
          }
        }).catch(() => {});
    }
    checkSubscriptionStatus();
    </script>
  </body>
</html>
