<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Invoicing - Register</title>
    <link rel="icon" type="image/png" href="images/invoicing-logo-simple.png" />

    <link href="assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
    <link
        href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
        rel="stylesheet" />
    <link href="assets/css/sb-admin-2.min.css" rel="stylesheet" />

    <style>
        :root {
            --bg1: #0b4bff;
            --bg2: #6a5cff;
            --card: #ffffff;
            --muted: #6b7280;
            --text: #111827;
            --line: #eef0f4;
            --shadow: 0 22px 70px rgba(16, 24, 40, .18);
            --radius: 18px;
        }

        body.bg-gradient-primary {
            background: radial-gradient(1200px 600px at 15% 10%, rgba(255, 255, 255, .20), transparent 55%),
                radial-gradient(900px 520px at 85% 15%, rgba(255, 255, 255, .18), transparent 60%),
                linear-gradient(135deg, var(--bg1), var(--bg2)) !important;
            min-height: 100vh;
        }

        .auth-wrap {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 32px 0;
        }

        /* Card */
        .auth-card {
            border: 1px solid rgba(255, 255, 255, .22) !important;
            border-radius: var(--radius) !important;
            overflow: hidden;
            background: rgba(255, 255, 255, .92);
            backdrop-filter: blur(8px);
            box-shadow: var(--shadow);
        }

        .auth-head {
            padding: 18px 22px;
            border-bottom: 1px solid var(--line);
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 220px;
        }

        .brand img {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            box-shadow: 0 8px 18px rgba(16, 24, 40, .10);
        }

        .brand .t1 {
            font-weight: 900;
            color: var(--text);
            line-height: 1.1;
        }

        .brand .t2 {
            font-size: .85rem;
            color: var(--muted);
            margin-top: 1px;
        }

        /* Steps */
        .steps {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .step-pill {
            display: flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #e5e7eb;
            background: #fff;
            padding: 8px 12px;
            border-radius: 999px;
            font-size: .86rem;
            color: #374151;
        }

        .step-dot {
            width: 26px;
            height: 26px;
            border-radius: 999px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            background: #f3f4f6;
            color: #111827;
        }

        .step-pill.active {
            border-color: rgba(37, 99, 235, .35);
            box-shadow: 0 10px 26px rgba(37, 99, 235, .14);
        }

        .step-pill.active .step-dot {
            background: rgba(37, 99, 235, .12);
            color: #2563eb;
        }

        .progress-mini {
            width: 210px;
            height: 8px;
            background: #eef2ff;
            border-radius: 999px;
            overflow: hidden;
            border: 1px solid #e5e7eb;
        }

        .progress-mini>div {
            height: 100%;
            width: 50%;
            background: linear-gradient(90deg, #2563eb, #7c3aed);
            border-radius: 999px;
            transition: width .2s ease;
        }

        .auth-body {
            padding: 22px;
            background: #fff;
        }

        .title {
            font-weight: 900;
            color: var(--text);
            margin: 0;
        }

        .subtitle {
            color: var(--muted);
            margin-top: 6px;
            font-size: .95rem;
        }

        /* Form */
        .required-note {
            display: block;
            margin: 12px 0 16px;
            font-size: .86rem;
            color: var(--muted);
            text-align: center;
            padding: 10px 12px;
            border: 1px dashed #e5e7eb;
            border-radius: 12px;
            background: #fafafa;
        }

        label {
            font-size: .90rem;
            margin-left: .35rem;
            color: #374151;
            font-weight: 700;
        }

        label.required::after {
            content: " *";
            color: #dc3545;
            font-weight: 900;
            margin-left: 2px;
        }

        .form-control {
            padding: 1.05rem 0.95rem !important;
            border-radius: 14px !important;
            border: 1px solid #e5e7eb !important;
            background: #fff !important;
            transition: box-shadow .15s ease, border-color .15s ease;
        }

        .form-control:focus {
            border-color: rgba(37, 99, 235, .55) !important;
            box-shadow: 0 0 0 .18rem rgba(37, 99, 235, .12) !important;
        }

        /* input with icon */
        .iwrap {
            position: relative;
        }

        .iwrap .icon {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            left: 14px;
            color: #9ca3af;
            pointer-events: none;
        }

        .iwrap .form-control {
            padding-left: 44px !important;
        }

        /* Password tool buttons */
        .input-group .btn {
            border-radius: 12px !important;
        }

        .input-group-append .btn {
            border: 1px solid #e5e7eb;
            background: #fff;
        }

        .input-group-append .btn:hover {
            background: #f9fafb;
        }

        /* Error / success helpers */
        .field-msg {
            display: none;
            margin-top: 6px;
            font-size: .85rem;
            color: #ef4444;
        }

        .has-error .form-control {
            border-color: rgba(239, 68, 68, .55) !important;
            box-shadow: 0 0 0 .18rem rgba(239, 68, 68, .10) !important;
        }

        .has-error .field-msg {
            display: block;
        }

        #passwordStrength {
            color: #6b7280;
        }

        /* Footer */
        .auth-footer {
            border-top: 1px solid var(--line);
            background: #fff;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap;
        }

        .footer-left {
            color: #9ca3af;
            font-size: .85rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn {
            border-radius: 14px !important;
            padding: .55rem 1.1rem !important;
            font-weight: 800;
        }

        .btn-primary {
            box-shadow: 0 12px 30px rgba(37, 99, 235, .22);
        }

        .btn-secondary {
            box-shadow: 0 10px 26px rgba(107, 114, 128, .18);
        }

        /* keep your footer ids */
        #btn-next,
        #btn-save {
            margin-left: 8px;
        }

        /* Password toolbar */
        .pw-wrap {
            position: relative;
        }

        .pw-wrap #password {
            padding-right: 150px !important;
            /* espaço para os botões */
        }

        .pw-tools {
            position: absolute;
            top: 50%;
            right: 10px;
            transform: translateY(-50%);
            display: inline-flex;
            gap: 8px;
            padding: 6px;
            border-radius: 14px;
            border: 1px solid #e5e7eb;
            background: rgba(255, 255, 255, .95);
            box-shadow: 0 10px 26px rgba(16, 24, 40, .08);
        }

        .pw-btn {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #fff;
            color: #374151;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: .15s ease;
        }

        .pw-btn:hover {
            background: #f9fafb;
            transform: translateY(-1px);
        }

        .pw-btn-primary {
            border-color: rgba(37, 99, 235, .35);
            background: rgba(37, 99, 235, .10);
            color: #2563eb;
        }

        .pw-btn-primary:hover {
            background: rgba(37, 99, 235, .16);
        }

        /* Responsivo: no mobile os botões descem */
        @media (max-width: 576px) {
            .pw-wrap #password {
                padding-right: .95rem !important;
            }

            .pw-tools {
                position: static;
                transform: none;
                margin-top: 10px;
                width: fit-content;
            }
        }

        /* =========================
   REGISTER - Mobile friendly
   ========================= */
        @media (max-width: 576px) {

            /* reduz padding geral */
            .auth-wrap {
                padding: 18px 0;
            }

            /* card ocupa melhor a tela */
            .auth-body {
                padding: 16px;
            }

            /* HEADER vira coluna */
            .auth-head {
                flex-direction: column;
                align-items: flex-start;
                padding: 14px 14px;
            }

            /* brand ocupa tudo */
            .brand {
                min-width: auto;
                width: 100%;
            }

            .brand .t1 {
                font-size: 1.05rem;
            }

            .brand .t2 {
                font-size: .85rem;
            }

            /* Steps: vira linha compacta e barra em baixo */
            .steps {
                width: 100%;
                justify-content: flex-start;
                gap: 8px;
            }

            /* pills menores */
            .step-pill {
                padding: 6px 10px;
                font-size: .80rem;
            }

            .step-dot {
                width: 22px;
                height: 22px;
                font-size: .85rem;
            }

            /* barra ocupa 100% e vai para linha inteira */
            .progress-mini {
                width: 100%;
                height: 10px;
                order: 3;
            }

            /* título e subtítulo */
            .title {
                font-size: 1.05rem;
            }

            .subtitle {
                font-size: .92rem;
            }

            /* inputs no iPhone não dão zoom (>=16px) */
            input.form-control,
            select.form-control,
            textarea.form-control {
                font-size: 16px !important;
            }

            /* labels e grupos */
            label {
                font-size: .88rem;
                margin-left: .15rem;
            }

            .form-group {
                margin-bottom: .9rem;
            }

            /* Nota obrigatórios */
            .required-note {
                text-align: left;
                font-size: .85rem;
                padding: 10px 12px;
            }

            /* Password: toolbar já tens, mas deixamos ela bem alinhada no mobile */
            .pw-tools {
                margin-top: 10px;
                width: 100%;
                justify-content: space-between;
            }

            .pw-btn {
                flex: 1;
                height: 44px;
                border-radius: 12px;
            }

            /* FOOTER vira coluna com botões full */
            .auth-footer {
                flex-direction: column;
                align-items: stretch;
                gap: 10px;
                padding: 12px 14px;
            }

            .footer-left {
                justify-content: center;
                text-align: center;
                width: 100%;
            }

            /* botões 100% */
            #next-footer,
            #save-footer {
                width: 100%;
            }

            #btn-next,
            #btn-save,
            #btn-prev {
                width: 100%;
                margin: 0 !important;
                padding: 12px 14px !important;
                font-size: 1rem;
            }

            /* quando estiveres no step 2 (btn-prev + btn-save), coloca em coluna com gap */
            #save-footer {
                display: flex;
                flex-direction: column;
                gap: 10px;
            }
        }

        /* Tablet pequeno (opcional): melhora um pouco também */
        @media (max-width: 768px) {
            .auth-card {
                border-radius: 16px !important;
            }
        }
    </style>
</head>

<body class="bg-gradient-primary">
    <div class="auth-wrap">
        <div class="container">
            <div class="row justify-content-center pt-2">
                <div class="col-12 col-md-10 col-lg-11 col-xl-11">

                    <div class="card auth-card o-hidden border-0">
                        <!-- HEADER -->
                        <div class="auth-head">
                            <div class="brand">
                                <img src="images/invoicing-logo-simple.png" alt="logo" />
                                <div>
                                    <div class="t1">Criar uma conta</div>
                                    <div class="t2" id="info-description">Informações da Empresa</div>
                                </div>
                            </div>

                            <div class="steps">
                                <div class="step-pill active" id="step1Pill">
                                    <div class="step-dot">1</div>
                                    <div>Empresa</div>
                                </div>
                                <div class="step-pill" id="step2Pill">
                                    <div class="step-dot">2</div>
                                    <div>Usuário</div>
                                </div>

                                <div class="progress-mini" aria-hidden="true">
                                    <div id="progressBar"></div>
                                </div>
                            </div>
                        </div>

                        <!-- BODY -->
                        <div class="auth-body">
                            <h5 class="title">Começar a usar o Invoicing</h5>
                            <div class="subtitle">Regista a empresa e cria o usuário administrador para entrar no
                                sistema.</div>

                            <form class="user mt-3" id="register-form">
                                <span class="required-note">
                                    <strong>Atenção:</strong> campos com <span class="text-danger">*</span> são
                                    obrigatórios.
                                </span>

                                <!-- STEP 1 -->
                                <div id="companyInfo">
                                    <div class="row">
                                        <div class="form-group col-md-5">
                                            <label class="required">Nome da Empresa</label>
                                            <div class="iwrap">
                                                <i class="fas fa-building icon"></i>
                                                <input type="text" class="form-control form-control-user"
                                                    id="companyName" placeholder="Ex: Sua Empresa" name="name"
                                                    required />
                                            </div>
                                            <div class="field-msg">Informe o nome da empresa.</div>
                                        </div>

                                        <div class="form-group col-md-3">
                                            <label class="required">NUIT</label>
                                            <div class="iwrap">
                                                <i class="fas fa-id-card icon"></i>
                                                <input type="text" class="form-control form-control-user"
                                                    id="companyNuit" placeholder="Ex: 123456789" name="nuit" required />
                                            </div>
                                            <div class="field-msg">NUIT inválido.</div>
                                        </div>

                                        <div class="form-group col-md-4">
                                            <label class="required">Contacto</label>
                                            <div class="iwrap">
                                                <i class="fas fa-phone icon"></i>
                                                <input type="text" class="form-control form-control-user"
                                                    id="companyPhone" placeholder="+258 8X XX XX XXX" name="contact"
                                                    required />
                                            </div>
                                            <div class="field-msg">Telefone inválido.</div>
                                        </div>

                                        <div class="form-group col-md-5">
                                            <label class="required">Endereço</label>
                                            <div class="iwrap">
                                                <i class="fas fa-map-marker-alt icon"></i>
                                                <input type="text" class="form-control form-control-user"
                                                    id="exampleCompanyAddress"
                                                    placeholder="Ex: Av. 25 de Setembro nº 113A" name="address"
                                                    required />
                                            </div>
                                            <div class="field-msg">Informe o endereço.</div>
                                        </div>

                                        <div class="form-group col-md-4">
                                            <label class="required">E-mail</label>
                                            <div class="iwrap">
                                                <i class="fas fa-envelope icon"></i>
                                                <input type="email" class="form-control form-control-user"
                                                    id="companyEmail" placeholder="empresa@dominio.com" name="email"
                                                    required />
                                            </div>
                                            <div class="field-msg">E-mail inválido.</div>
                                        </div>

                                        <div class="form-group col-md-3">
                                            <label>Website</label>
                                            <div class="iwrap">
                                                <i class="fas fa-globe-africa icon"></i>
                                                <input type="text" class="form-control form-control-user"
                                                    id="exampleCompanyWebsite" placeholder="https://empresa.com"
                                                    name="website" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- STEP 2 -->
                                <div id="userInfo" class="d-none">
                                    <div class="row">
                                        <div class="form-group col-md-4">
                                            <label class="required">Nome</label>
                                            <div class="iwrap">
                                                <i class="fas fa-user icon"></i>
                                                <input type="text" class="form-control form-control-user" id="firstName"
                                                    placeholder="Ex: Nome" name="firstName" required />
                                            </div>
                                            <div class="field-msg">Informe o nome.</div>
                                        </div>

                                        <div class="form-group col-md-4">
                                            <label class="required">Sobrenome</label>
                                            <div class="iwrap">
                                                <i class="fas fa-user-tag icon"></i>
                                                <input type="text" class="form-control form-control-user" id="lastName"
                                                    placeholder="Ex: apelido" name="lastName" required />
                                            </div>
                                            <div class="field-msg">Informe o sobrenome.</div>
                                        </div>

                                        <div class="form-group col-md-4">
                                            <label class="required">E-mail</label>
                                            <div class="iwrap">
                                                <i class="fas fa-at icon"></i>
                                                <input type="email" class="form-control form-control-user"
                                                    id="userEmail" placeholder="admin@empresa.com" name="useremail"
                                                    required />
                                            </div>
                                            <div class="field-msg">E-mail inválido.</div>
                                        </div>

                                        <div class="form-group col-md-4">
                                            <label class="required">Telefone</label>
                                            <div class="iwrap">
                                                <i class="fas fa-mobile-alt icon"></i>
                                                <input type="text" class="form-control form-control-user" id="userPhone"
                                                    placeholder="+258 8X XX XX XXX" name="usercontact" required />
                                            </div>
                                            <div class="field-msg">Telefone inválido.</div>
                                        </div>

                                        <!-- PASSWORDS: mesma linha -->
                                        <div class="form-group col-md-8">
                                            <div class="row">
                                                <!-- Palavra-passe -->
                                                <div class="form-group col-md-6 mb-0">
                                                    <label class="required">Palavra-passe</label>

                                                    <div class="pw-wrap">
                                                        <input type="password" class="form-control form-control-user"
                                                            id="password" placeholder="Crie uma palavra-passe forte"
                                                            name="userpassword" required />

                                                        <!-- toolbar (IDs mantidos!) -->
                                                        <div class="pw-tools" role="group"
                                                            aria-label="Ferramentas de palavra-passe">
                                                            <button class="pw-btn" type="button" id="togglePassword"
                                                                title="Mostrar/Ocultar">
                                                                <i class="fas fa-eye"></i>
                                                            </button>
                                                            <button class="pw-btn" type="button" id="copyPassword"
                                                                title="Copiar">
                                                                <i class="fas fa-copy"></i>
                                                            </button>
                                                            <button class="pw-btn pw-btn-primary" type="button"
                                                                id="generatePassword" title="Gerar palavra-passe forte">
                                                                <i class="fas fa-random"></i>
                                                            </button>
                                                        </div>
                                                    </div>

                                                    <small id="passwordStrength" class="form-text mt-2">
                                                        Dica: use 8+ caracteres, letras maiúsculas/minúsculas, número e
                                                        símbolo.
                                                    </small>
                                                </div>

                                                <!-- Repetir palavra-passe -->
                                                <div class="form-group col-md-6 mb-0">
                                                    <label class="required">Repetir palavra-passe</label>
                                                    <div class="iwrap">
                                                        <i class="fas fa-lock icon"></i>
                                                        <input type="password" class="form-control form-control-user"
                                                            id="repeatPassword" placeholder="Repita a palavra-passe"
                                                            name="password2" required />
                                                    </div>
                                                    <div class="field-msg">As palavras-passe não coincidem.</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <!-- FOOTER (mantive teus IDs) -->
                        <div class="auth-footer">
                            <div class="footer-left">
                                <i class="fas fa-shield-alt"></i>
                                <span>Os teus dados são tratados com segurança.</span>
                            </div>

                            <div class="d-flex align-items-center">
                                <div id="next-footer">
                                    <button type="button" id="btn-next" class="btn btn-primary btn-sm">
                                        Próximo <i class="fas fa-arrow-right ml-2"></i>
                                    </button>
                                </div>

                                <div id="save-footer" class="save-footer d-none">
                                    <button type="button" id="btn-prev" class="btn btn-secondary btn-sm">
                                        <i class="fas fa-arrow-left mr-2"></i> Anterior
                                    </button>
                                    <button type="button" id="btn-save" class="btn btn-primary btn-sm">
                                        Salvar <i class="fas fa-check ml-2"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-3" style="color: rgba(255,255,255,.85); font-size:.9rem;">
                        Já tem conta? <a href="/login"
                            style="color:#fff; text-decoration:underline; font-weight:800;">Entrar</a>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

        <script src="https://code.jquery.com/jquery-3.7.1.js"
            integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4=" crossorigin="anonymous"></script>
        <script src="assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
        <script src="assets/vendor/jquery-easing/jquery.easing.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

        <script src="assets/js/sb-admin-2.min.js"></script>
        <script src="assets/js/confetti.js"></script>
        <script src="assets/js/register.js"></script>

        <!-- (Opcional) mini script só para a UI dos passos (não interfere com tua lógica) -->
        <script>
            // Atualiza o visual (passos + barra) sem depender do teu register.js
            function setStepUI(step) {
                const step1 = document.getElementById("step1Pill");
                const step2 = document.getElementById("step2Pill");
                const bar = document.getElementById("progressBar");
                const desc = document.getElementById("info-description");

                if (!step1 || !step2 || !bar || !desc) return;

                if (step === 1) {
                    step1.classList.add("active");
                    step2.classList.remove("active");
                    bar.style.width = "50%";
                    desc.textContent = "Informações da Empresa";
                } else {
                    step1.classList.remove("active");
                    step2.classList.add("active");
                    bar.style.width = "100%";
                    desc.textContent = "Informações do Usuário";
                }
            }

            // Observa a troca de telas pelo teu código (d-none)
            const companyInfo = document.getElementById("companyInfo");
            const userInfo = document.getElementById("userInfo");

            function syncStep() {
                if (!userInfo) return;
                const isUserVisible = !userInfo.classList.contains("d-none");
                setStepUI(isUserVisible ? 2 : 1);
            }

            // Inicial + quando classes mudarem
            syncStep();
            const obs = new MutationObserver(syncStep);
            if (companyInfo) obs.observe(companyInfo, { attributes: true, attributeFilter: ["class"] });
            if (userInfo) obs.observe(userInfo, { attributes: true, attributeFilter: ["class"] });
        </script>
</body>

