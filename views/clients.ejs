<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Invoicing | <%- title %></title>
    <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png" />
    <!-- Custom fonts for this template -->
    <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link
        href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
        rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
        integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- Custom styles for this template -->
    <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet">

    <!-- Custom styles for this page -->
    <link href="/assets/vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link href="/assets/css/custom.css" rel="stylesheet" />
    <style>
        body {
            font-size: 0.85rem !important;
        }

        table {
            font-size: 0.8rem !important;
        }

        table tr th,
        table tr td {
            padding: 0.3rem !important;
        }

        table tr td:last-child {
            text-align: center !important;
        }

        .page-header-actions {
            gap: 0.5rem;
        }

        .mobile-client-card {
            border: 1px solid #e3e6f0;
            border-radius: 12px;
            padding: 0.9rem;
            margin-bottom: 0.75rem;
            background: #fff;
            box-shadow: 0 0.15rem 0.35rem rgba(58, 59, 69, 0.08);
        }

        .mobile-client-card .client-name {
            font-size: 0.95rem;
            font-weight: 700;
            color: #2e2f37;
            margin-bottom: 0.5rem;
        }

        .mobile-client-meta {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
            margin-bottom: 0.75rem;
        }

        .mobile-client-meta div {
            font-size: 0.8rem;
            color: #5a5c69;
            line-height: 1.35;
        }

        .mobile-client-meta strong {
            color: #3a3b45;
        }

        .mobile-client-actions {
            display: flex;
            gap: 0.5rem;
        }

        .mobile-client-actions .btn {
            flex: 1;
        }

        @media (max-width: 767.98px) {
            .container-fluid {
                padding-left: 0.75rem !important;
                padding-right: 0.75rem !important;
            }

            .d-sm-flex.align-items-center.justify-content-between.mb-3 {
                display: flex !important;
                flex-direction: column;
                align-items: stretch !important;
            }

            .d-sm-flex.align-items-center.justify-content-between.mb-3 h1 {
                margin-bottom: 0.75rem !important;
            }

            #btn-open-client-modal {
                width: 100%;
            }

            .modal-dialog {
                margin: 0.75rem;
            }

            .modal-body .form-group {
                margin-bottom: 0.75rem;
            }
        }
    </style>
</head>

<body id="page-top">

    <!-- Page Wrapper -->
    <div id="wrapper">
        <%- include('partials/sidebar') %>

            <!-- Content Wrapper -->
            <div id="content-wrapper" class="d-flex flex-column">

                <!-- Main Content -->
                <div id="content">

                    <%- include('partials/topbar') %>
                        <!-- Begin Page Content -->
                        <div class="container-fluid">

                            <!-- Page Heading -->
                            <div class="d-sm-flex align-items-center justify-content-between mb-3">
                                <h1 class="h3 mb-2 text-gray-800" style="font-size: 1.2rem;">Clientes</h1>
                                <button type="button" class="btn btn-primary btn-sm" id="btn-open-client-modal"><i
                                        class="fa-solid fa-user-plus"></i> Novo Cliente</button>
                            </div>
                            <!-- DataTales Example -->
                            <div class="card shadow mb-4 d-none d-md-block">
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                                            <thead>
                                                <tr class="bg-secondary text-white">
                                                    <th>Nome do Cliente</th>
                                                    <th>E-mail</th>
                                                    <th>Contacto</th>
                                                    <th>Nuit</th>
                                                    <th class="text-center">Acções</th>
                                                </tr>
                                            </thead>
                                            <tbody>

                                            </tbody>
                                            <tfoot>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <!-- Versão mobile -->
                            <div class="d-block d-md-none" id="mobileClientsList"></div>
                        </div>
                </div>
                <!-- /.container-fluid -->
                <%- include('partials/copyright') %>
            </div>
            <!-- End of Main Content -->

    </div>
    <!-- End of Content Wrapper -->

    <!-- End of Page Wrapper -->

    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>


    <div class="modal fade" id="createClientModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
        aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalLabel"><strong><i class="fa-solid fa-pen-to-square"></i>
                            Adicionar Cliente</strong></h6>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <form id="create-client-form">
                    <div class="modal-body row g-3">
                        <div class="form-group col-md-8">
                            <label for="client-name">Nome do Cliente</label>
                            <input type="text" class="form-control form-control-sm" id="client-name" name="name"
                                placeholder="Nome do Cliente" required>
                        </div>
                        <div class="form-group col-md-4">
                            <label for="client-nuit">NUIT</label>
                            <input type="text" class="form-control form-control-sm" id="client-nuit" name="nuit"
                                placeholder="Nuit" required>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="client-email">E-mail</label>
                            <input type="email" class="form-control form-control-sm" id="client-email" name="email"
                                placeholder="E-mail" required>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="client-phone">Contacto</label>
                            <input type="text" class="form-control form-control-sm" id="client-phone" name="phone"
                                placeholder="Contacto" required>
                        </div>
                        <div class="form-group col-md-12">
                            <label for="client-phone">Endereço</label>
                            <input type="text" class="form-control form-control-sm" id="client-address" name="address"
                                placeholder="Endereço" required>
                        </div>
                    </div>
                </form>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" type="button" data-dismiss="modal">Fechar</button>
                    <button id="btn-create-client" class="btn btn-primary btn-sm">Salvar</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="updateClientModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
        aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title" id="exampleModalLabel"><strong><i class="fa-solid fa-pen-to-square"></i>
                            Actualizar Cliente</strong></h6>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <form id="update-client-form">
                    <div class="modal-body row g-3">
                        <div class="form-group col-md-8">
                            <label for="client-name">Nome do Cliente</label>
                            <input type="text" class="form-control form-control-sm" id="client-name-update" name="name"
                                placeholder="Nome do Cliente" required>
                        </div>
                        <div class="form-group col-md-4">
                            <label for="client-nuit">NUIT</label>
                            <input type="text" class="form-control form-control-sm" id="client-nuit-update" name="nuit"
                                placeholder="Nuit" required>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="client-email">E-mail</label>
                            <input type="email" class="form-control form-control-sm" id="client-email-update"
                                name="email" placeholder="E-mail" required>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="client-phone">Contacto</label>
                            <input type="text" class="form-control form-control-sm" id="client-phone-update"
                                name="phone" placeholder="Contacto" required>
                        </div>
                        <div class="form-group col-md-12">
                            <label for="client-phone">Endereço</label>
                            <input type="text" class="form-control form-control-sm" id="client-address-update"
                                name="address" placeholder="Endereço" required>
                        </div>
                    </div>
                </form>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" type="button" data-dismiss="modal">Fechar</button>
                    <button id="btn-update-client" class="btn btn-primary btn-sm">Actualizar</button>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

        <!-- Page level plugins -->
        <script src="/assets/vendor/datatables/jquery.dataTables.min.js"></script>
        <script src="/assets/vendor/datatables/dataTables.bootstrap4.min.js"></script>
        <!-- Toastify -->
        <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
        <!-- Page level custom scripts -->
        <script src="/assets/js/clients.js"></script>
</body>

</html>