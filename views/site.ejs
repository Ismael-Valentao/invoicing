  <!-- Dynamic Pricing -->
  <script>
  (function() {
    var descriptions = {
      FREE: { title: 'Plano Gratuito', desc: 'Ideal para quem está a começar e quer experimentar a plataforma.', cta: 'Começar agora', sub: 'Sem cartão de crédito' },
      BASIC: { title: 'Plano Profissional', desc: 'Para negócios que já vendem regularmente e precisam de mais capacidade.', cta: 'Experimentar 30 dias grátis', sub: 'Começa grátis, paga depois', featured: true, popular: 'Mais Popular' },
      PREMIUM: { title: 'Plano Empresarial', desc: 'Para empresas com maior volume de operações e equipas maiores.', cta: 'Experimentar 30 dias grátis', sub: 'Tudo ilimitado' }
    };
    var delays = { FREE: 100, BASIC: 200, PREMIUM: 300 };

    function fmt(v) { return v === 'Ilimitado' ? v : v; }
    function isUnlimited(v) { return v === 'Ilimitado' || v >= 999999; }

    function limitLine(val, singular, plural) {
      if (isUnlimited(val)) return '<li><i class="bi bi-check"></i> <span>' + (plural || singular) + ' <strong>ilimitados</strong></span></li>';
      return '<li><i class="bi bi-check"></i> <span><strong>' + val + '</strong> ' + (plural || singular) + '</span></li>';
    }

    function featureLine(enabled, label) {
      if (enabled) return '<li><i class="bi bi-check"></i> <span>' + label + '</span></li>';
      return '<li class="na"><i class="bi bi-x"></i> <span>' + label + '</span></li>';
    }

    function buildCard(plan) {
      var info = descriptions[plan.name] || { title: plan.label, desc: '', cta: 'Registar', sub: '' };
      var delay = delays[plan.name] || 100;
      var price = plan.priceMZN || 0;
      var period = plan.name === 'FREE' ? ' / 30 dias' : ' / mês';
      var priceFormatted = price === 0 ? '0' : price.toLocaleString('pt-MZ');

      var l = plan.limits;

      return '<div class="col-lg-4" data-aos="zoom-in" data-aos-delay="' + delay + '">'
        + '<div class="pricing-item' + (info.featured ? ' featured' : '') + '">'
        + (info.popular ? '<p class="popular">' + info.popular + '</p>' : '')
        + '<h3>' + info.title + '</h3>'
        + '<p class="description">' + info.desc + '</p>'
        + '<h4><sup>MT</sup>' + priceFormatted + '<span>' + period + '</span></h4>'
        + '<a href="/register" class="cta-btn">' + info.cta + '</a>'
        + '<p class="text-center small">' + info.sub + '</p>'
        + '<ul>'
        + limitLine(l.maxInvoicesPerMonth, 'factura por mês', 'facturas por mês')
        + limitLine(l.maxSalesPerMonth, 'venda por mês', 'vendas por mês')
        + limitLine(l.maxClients, 'cliente', 'clientes')
        + limitLine(l.maxProducts, 'produto', 'produtos')
        + limitLine(l.maxUsers, 'utilizador', 'utilizadores')
        + featureLine(true, 'Exportação em PDF')
        + featureLine(l.excelExport, 'Exportação Excel')
        + featureLine(l.advancedReports, 'Relatórios avançados')
        + '</ul></div></div>';
    }

    fetch('/api/subscriptions/plans')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.success || !data.plans.length) return;
        var order = ['FREE', 'BASIC', 'PREMIUM'];
        var sorted = order.map(function(n) { return data.plans.find(function(p) { return p.name === n; }); }).filter(Boolean);
        document.getElementById('pricingCards').innerHTML = sorted.map(buildCard).join('');
      })
      .catch(function() {});
  })();
  </script>

  <!-- Funnel Wizard JS -->
  <script>
  (function() {
    var overlay = document.getElementById('funnelOverlay');
    var selectedNeeds = new Set();
    var selectedSize = null;

    // Tips database
    var tipsByNeed = {
      invoicing: {
        icon: 'bi-receipt', color: '#228CDF',
        text: '<strong>Facturação:</strong> Começa por configurar os dados da tua empresa (NIF, morada, logotipo) em Definições. Assim as tuas facturas saem profissionais desde o primeiro dia.'
      },
      sales: {
        icon: 'bi-cart-check', color: '#1cc88a',
        text: '<strong>Vendas:</strong> Adiciona os teus produtos com preços antes de registar vendas. Assim o processo fica mais rápido — basta seleccionar o produto e a quantidade.'
      },
      stock: {
        icon: 'bi-box-seam', color: '#e74a3b',
        text: '<strong>Stock:</strong> Regista o stock inicial de cada produto. O sistema actualiza automaticamente a cada venda. Usa os alertas de stock baixo para evitar rupturas.'
      },
      clients: {
        icon: 'bi-people', color: '#f6c23e',
        text: '<strong>Clientes:</strong> Cadastra os teus clientes com NUIT e contacto. Assim poderás emitir facturas personalizadas e consultar o histórico de compras de cada um.'
      },
      quotations: {
        icon: 'bi-file-earmark-text', color: '#6f42c1',
        text: '<strong>Cotações:</strong> Cria cotações e converte-as em facturas com um clique quando o cliente aceitar. Poupa tempo e evita retrabalho.'
      },
      reports: {
        icon: 'bi-graph-up', color: '#36b9cc',
        text: '<strong>Relatórios:</strong> Consulta o dashboard regularmente para acompanhar vendas, produtos mais vendidos e desempenho do negócio. Usa os filtros de data para comparar períodos.'
      }
    };

    // Plan recommendations based on size (loaded from API, with fallbacks)
    var plansBySize = {
      starting: { name: 'Plano Gratuito',      price: '0',     unit: '30 dias',  badge: 'IDEAL PARA COMEÇAR' },
      small:    { name: 'Plano Profissional',   price: '799',   unit: 'MZN/mês',  badge: 'RECOMENDADO' },
      growing:  { name: 'Plano Empresarial',    price: '1.299', unit: 'MZN/mês',  badge: 'MAIS COMPLETO' }
    };
    // Update with real prices from API
    fetch('/api/subscriptions/plans').then(function(r){return r.json();}).then(function(d) {
      if (!d.success) return;
      var map = {}; d.plans.forEach(function(p){map[p.name]=p;});
      if (map.FREE) plansBySize.starting = { name: map.FREE.label, price: String(map.FREE.priceMZN||0), unit: map.FREE.priceLabel||'30 dias', badge: 'IDEAL PARA COMEÇAR' };
      if (map.BASIC) plansBySize.small = { name: map.BASIC.label, price: String(map.BASIC.priceMZN||799), unit: 'MZN/mês', badge: 'RECOMENDADO' };
      if (map.PREMIUM) plansBySize.growing = { name: map.PREMIUM.label, price: String(map.PREMIUM.priceMZN||1299), unit: 'MZN/mês', badge: 'MAIS COMPLETO' };
    }).catch(function(){});

    // Enable/disable next buttons on selection
    document.querySelectorAll('#needsGrid .funnel-option input').forEach(function(cb) {
      cb.addEventListener('change', function() {
        var need = this.closest('.funnel-option').dataset.need;
        if (this.checked) selectedNeeds.add(need); else selectedNeeds.delete(need);
        document.getElementById('btnStep1Next').disabled = selectedNeeds.size === 0;
      });
    });

    document.querySelectorAll('#sizeGrid .funnel-option input').forEach(function(radio) {
      radio.addEventListener('change', function() {
        selectedSize = this.closest('.funnel-option').dataset.size;
        document.getElementById('btnStep2Next').disabled = false;
      });
    });

    // Navigation
    window.funnelNext = function(step) {
      document.querySelectorAll('.funnel-step').forEach(function(s) { s.style.display = 'none'; });
      document.getElementById('funnelStep' + step).style.display = 'block';

      var pct = Math.round((step / 3) * 100);
      document.getElementById('funnelProgressBar').style.width = pct + '%';
      document.getElementById('funnelStepLabel').textContent = 'PASSO ' + step + ' DE 3';
      document.getElementById('funnelStepPercent').textContent = pct + '%';

      if (step === 3) buildResult();
    };

    function buildResult() {
      // Plan
      var plan = plansBySize[selectedSize] || plansBySize.small;

      // If they need reports or have many needs, push to higher plan
      if (selectedSize === 'starting' && (selectedNeeds.has('reports') || selectedNeeds.size >= 4)) {
        plan = plansBySize.small;
      }

      document.getElementById('funnelPlanName').textContent = plan.name;
      document.getElementById('funnelPlanPrice').innerHTML = plan.price + ' <small style="font-size:.9rem; color:#858796;">' + plan.unit + '</small>';
      document.getElementById('funnelPlanBadge').textContent = plan.badge;

      // Tips
      var tipsHtml = '';
      selectedNeeds.forEach(function(need) {
        var tip = tipsByNeed[need];
        if (tip) {
          tipsHtml += '<div class="funnel-tip-item">'
            + '<div class="funnel-tip-icon" style="background:' + tip.color + ';">'
            + '<i class="bi ' + tip.icon + '"></i></div>'
            + '<div>' + tip.text + '</div></div>';
        }
      });

      // General tip
      tipsHtml += '<div class="funnel-tip-item">'
        + '<div class="funnel-tip-icon" style="background:#858796;"><i class="bi bi-star"></i></div>'
        + '<div><strong>Dica geral:</strong> Depois de criar a conta, completa o checklist de configuração no dashboard. Em poucos minutos terás tudo pronto para começar a vender.</div></div>';

      document.getElementById('funnelTips').innerHTML = tipsHtml;
    }

    window.openFunnel = function() {
      // Reset state
      selectedNeeds.clear();
      selectedSize = null;
      document.querySelectorAll('.funnel-option input').forEach(function(i) { i.checked = false; });
      document.getElementById('btnStep1Next').disabled = true;
      document.getElementById('btnStep2Next').disabled = true;
      document.querySelectorAll('.funnel-step').forEach(function(s) { s.style.display = 'none'; });
      document.getElementById('funnelStep1').style.display = 'block';
      document.getElementById('funnelProgressBar').style.width = '33%';
      document.getElementById('funnelStepLabel').textContent = 'PASSO 1 DE 3';
      document.getElementById('funnelStepPercent').textContent = '33%';
      overlay.style.display = 'block';
      document.body.style.overflow = 'hidden';
    };

    window.closeFunnel = function() {
      overlay.style.display = 'none';
      document.body.style.overflow = '';
    };

    // Close on overlay click (outside the card)
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) closeFunnel();
    });

    // Close on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && overlay.style.display === 'block') closeFunnel();
    });
  })();
  </script>

