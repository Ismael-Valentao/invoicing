<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>Invoicing — Criar Conta</title>
  <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png">
  <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css?family=Nunito:400,600,700,800" rel="stylesheet">
  <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(135deg, #228CDF 0%, #1cc88a 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .register-card { max-width: 440px; width: 100%; background: #fff; border-radius: 16px; box-shadow: 0 16px 60px rgba(0,0,0,0.15); overflow: hidden; }
    .register-header { background: #fff; padding: 32px 32px 16px; text-align: center; }
    .register-header h2 { font-weight: 800; color: #2e2e46; margin-bottom: 4px; }
    .register-header p { color: #858796; font-size: .9rem; }
    .register-body { padding: 0 32px 32px; }
    .form-control { border-radius: 8px; padding: 10px 14px; font-size: .9rem; }
    .form-control:focus { border-color: #228CDF; box-shadow: 0 0 0 3px rgba(34,140,223,0.15); }
    .btn-register { background: linear-gradient(135deg, #228CDF, #1cc88a); border: none; border-radius: 8px; padding: 12px; font-weight: 700; font-size: 1rem; color: #fff; width: 100%; }
    .btn-register:hover { opacity: 0.9; color: #fff; }
    .btn-register:disabled { opacity: 0.6; }
    .password-toggle { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #858796; }
    .pw-strength { height: 4px; border-radius: 2px; margin-top: 4px; transition: all .3s; }
    .divider { display: flex; align-items: center; gap: 12px; color: #858796; font-size: .8rem; margin: 16px 0; }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #e3e6f0; }
    .trust-row { display: flex; justify-content: center; gap: 20px; margin-top: 16px; font-size: .75rem; color: #858796; }
    .trust-row i { margin-right: 4px; }
    .error-msg { display: none; background: #f8d7da; color: #721c24; padding: 10px 14px; border-radius: 8px; font-size: .85rem; margin-bottom: 12px; }
  </style>
</head>
<body>
  <div class="register-card">
    <div class="register-header">
      <img src="https://bitiray.com/public/assets/images/logos/invoicing-logo.png" style="height: 40px; margin-bottom: 12px;" alt="Invoicing">
      <h2>Criar conta grátis</h2>
      <p>Começa a usar em menos de 1 minuto</p>
    </div>

    <div class="register-body">
      <div class="error-msg" id="errorMsg"></div>

      <form id="registerForm" autocomplete="off">
        <div class="form-group">
          <label class="small font-weight-bold">Nome completo</label>
          <input type="text" class="form-control" id="regName" placeholder="Ex: João Silva" required autofocus />
        </div>

        <div class="form-group">
          <label class="small font-weight-bold">Email</label>
          <input type="email" class="form-control" id="regEmail" placeholder="joao@exemplo.com" required />
        </div>

        <div class="form-group" style="position:relative;">
          <label class="small font-weight-bold">Password</label>
          <input type="password" class="form-control" id="regPassword" placeholder="Mínimo 8 caracteres" required minlength="8" />
          <span class="password-toggle" onclick="togglePw()"><i class="fas fa-eye" id="pwIcon"></i></span>
          <div class="pw-strength" id="pwStrength"></div>
        </div>

        <div class="form-group" style="position:relative;">
          <label class="small font-weight-bold">Confirmar password</label>
          <input type="password" class="form-control" id="regPassword2" placeholder="Repita a password" required />
        </div>

        <button type="submit" class="btn btn-register" id="btnRegister">
          <i class="fas fa-rocket mr-2"></i>Criar conta grátis
        </button>
      </form>

      <div class="divider">ou</div>

      <div class="text-center">
        <a href="/login" class="small">Já tem conta? <strong>Faça login</strong></a>
      </div>

      <div class="trust-row">
        <span><i class="fas fa-lock"></i>Dados seguros</span>
        <span><i class="fas fa-credit-card"></i>Sem cartão</span>
        <span><i class="fas fa-clock"></i>30 dias grátis</span>
      </div>

      <div class="text-center mt-3">
        <a href="/terms" class="small text-muted">Termos</a>
        <span class="text-muted small mx-1">&bull;</span>
        <a href="/privacy" class="small text-muted">Privacidade</a>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
  <script>
  function togglePw() {
    var pw = document.getElementById('regPassword');
    var icon = document.getElementById('pwIcon');
    if (pw.type === 'password') { pw.type = 'text'; icon.className = 'fas fa-eye-slash'; }
    else { pw.type = 'password'; icon.className = 'fas fa-eye'; }
  }

  document.getElementById('regPassword').addEventListener('input', function() {
    var v = this.value;
    var bar = document.getElementById('pwStrength');
    var score = 0;
    if (v.length >= 8) score++;
    if (/[A-Z]/.test(v)) score++;
    if (/[0-9]/.test(v)) score++;
    if (/[^A-Za-z0-9]/.test(v)) score++;
    var colors = ['#e74a3b', '#f6c23e', '#228CDF', '#1cc88a'];
    bar.style.width = (score * 25) + '%';
    bar.style.background = colors[score - 1] || '#e3e6f0';
  });

  document.getElementById('registerForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    var name = document.getElementById('regName').value.trim();
    var email = document.getElementById('regEmail').value.trim();
    var pw = document.getElementById('regPassword').value;
    var pw2 = document.getElementById('regPassword2').value;
    var errEl = document.getElementById('errorMsg');
    var btn = document.getElementById('btnRegister');

    errEl.style.display = 'none';

    if (pw !== pw2) {
      errEl.textContent = 'As passwords não coincidem.';
      errEl.style.display = 'block';
      return;
    }
    if (pw.length < 8) {
      errEl.textContent = 'Password deve ter pelo menos 8 caracteres.';
      errEl.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>A criar conta...';

    try {
      var res = await fetch('/api/company/quick-register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, email: email, password: pw })
      });
      var data = await res.json();

      if (data.success) {
        // Confetti
        confetti({ particleCount: 150, spread: 80, origin: { y: 0.6 } });

        btn.innerHTML = '<i class="fas fa-check mr-2"></i>Conta criada!';
        btn.style.background = '#1cc88a';

        errEl.style.display = 'block';
        errEl.style.background = '#d4edda';
        errEl.style.color = '#155724';
        errEl.innerHTML = '<strong>Conta criada com sucesso!</strong> A redirecionar para o login...';

        setTimeout(function() {
          window.location.href = '/login';
        }, 2500);
      } else {
        errEl.textContent = data.message || 'Erro ao criar conta.';
        errEl.style.display = 'block';
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-rocket mr-2"></i>Criar conta grátis';
      }
    } catch (err) {
      errEl.textContent = 'Erro de ligação. Tente novamente.';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-rocket mr-2"></i>Criar conta grátis';
    }
  });
  </script>
</body>
</html>
