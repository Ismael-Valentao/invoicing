<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Invoicing | Página não encontrada</title>

    <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png" />
    <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet" />
    <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet" />

    <style>
      body {
        background: #f8f9fc;
      }
      .error-wrap {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 32px 0;
      }
      .error-card {
        border: 0;
        border-radius: 16px;
        overflow: hidden;
      }
      .error-hero {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
        color: #fff;
      }
      .code-404 {
        font-size: 70px;
        font-weight: 900;
        letter-spacing: 2px;
        line-height: 1;
      }
      .soft {
        opacity: .9;
      }
      .kbd {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 12px;
        padding: 2px 8px;
        border-radius: 8px;
        background: #eef2ff;
        color: #1f3bb3;
        border: 1px solid rgba(78,115,223,.25);
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .btn-round { border-radius: 999px; }
      .quicklinks .btn {
        text-align: left;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        border-radius: 12px;
      }
      .path {
        word-break: break-all;
      }
    </style>
  </head>

  <body>
    <div class="container error-wrap">
      <div class="row justify-content-center w-100">
        <div class="col-xl-10 col-lg-11">
          <div class="card shadow-lg error-card">
            <div class="row no-gutters">
              <!-- Left / Hero -->
              <div class="col-lg-5 error-hero p-4 p-lg-5 d-flex flex-column justify-content-between">
                <div>
                  <div class="d-flex align-items-center mb-4" style="gap:10px;">
                    <img src="/images/invoicing-logo-simple.png" alt="logo" style="width:40px;height:40px;border-radius:10px;background:#fff;padding:6px;">
                    <div>
                      <div class="font-weight-bold">Invoicing</div>
                      <small class="soft">Página não encontrada</small>
                    </div>
                  </div>

                  <div class="code-404">404</div>
                  <div class="mt-3 soft">
                    Não conseguimos encontrar esta página.
                  </div>

                  <div class="mt-4">
                    <div class="kbd">
                      <i class="fas fa-link"></i>
                      <span class="path"><%= (typeof requestedUrl !== 'undefined' && requestedUrl) ? requestedUrl : (typeof url !== 'undefined' ? url : '') %></span>
                    </div>
                  </div>
                </div>

                <div class="mt-4 soft">
                  <small>
                    Dica: verifique o link ou volte ao início. Se isto acontecer sempre, contacte o suporte.
                  </small>
                </div>
              </div>

              <!-- Right / Actions -->
              <div class="col-lg-7 p-4 p-lg-5">
                <h4 class="text-gray-900 mb-2"><strong>Ups… esta página não existe</strong></h4>
                <p class="text-muted mb-4">
                  Pode ter sido removida, o link pode estar errado, ou você não tem acesso.
                </p>

                <div class="d-flex flex-wrap" style="gap:10px;">
                  <a class="btn btn-primary btn-round" href="/dashboard">
                    <i class="fas fa-home mr-2"></i> Ir para o Dashboard
                  </a>
                  <button class="btn btn-outline-secondary btn-round" type="button" onclick="history.back()">
                    <i class="fas fa-arrow-left mr-2"></i> Voltar
                  </button>
                </div>

                <hr class="my-4" />

                <h6 class="text-gray-800 mb-3"><strong>Acesso rápido</strong></h6>

                <div class="row quicklinks">
                  <!-- Se estiveres a usar req.user.company.modules -->
                  <% const mods = (user && user.company && user.company.modules) ? user.company.modules : null; %>

                  <% if (mods && mods.sales) { %>
                    <div class="col-md-6 mb-3">
                      <a class="btn btn-light border w-100" href="/new-sale">
                        <span><i class="fas fa-cash-register mr-2 text-primary"></i> Nova Venda</span>
                        <i class="fas fa-chevron-right text-muted"></i>
                      </a>
                    </div>
                    <div class="col-md-6 mb-3">
                      <a class="btn btn-light border w-100" href="/sales">
                        <span><i class="fas fa-receipt mr-2 text-primary"></i> Lista de Vendas</span>
                        <i class="fas fa-chevron-right text-muted"></i>
                      </a>
                    </div>
                  <% } %>

                  <% if (mods && mods.invoicing) { %>
                    <div class="col-md-6 mb-3">
                      <a class="btn btn-light border w-100" href="/new-invoice">
                        <span><i class="fas fa-file-invoice-dollar mr-2 text-success"></i> Nova Factura</span>
                        <i class="fas fa-chevron-right text-muted"></i>
                      </a>
                    </div>
                    <div class="col-md-6 mb-3">
                      <a class="btn btn-light border w-100" href="/invoices">
                        <span><i class="fas fa-list mr-2 text-success"></i> Lista de Facturas</span>
                        <i class="fas fa-chevron-right text-muted"></i>
                      </a>
                    </div>
                  <% } %>

                  <div class="col-md-12">
                    <a class="btn btn-light border w-100" href="/settings">
                      <span><i class="fas fa-cog mr-2 text-secondary"></i> Configurações</span>
                      <i class="fas fa-chevron-right text-muted"></i>
                    </a>
                  </div>
                </div>

                <div class="mt-4 text-center text-muted">
                  <small>Invoicing © <%= new Date().getFullYear() %></small>
                </div>
              </div>
            </div>
          </div>

          <div class="text-center mt-3">
            <small class="text-muted">
              Se acha que isto é um erro, copie o link e envie ao suporte.
            </small>
          </div>

        </div>
      </div>
    </div>

    <script src="/assets/vendor/jquery/jquery.min.js"></script>
    <script src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  </body>
</html>