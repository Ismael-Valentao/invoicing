<!-- Sidebar -->
<ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">
  <% const isAdmin=currentUser?.role==='ADMIN' ; const can=(permission)=> {
    if (isAdmin) return true;
    return !!currentUser?.permissions?.[permission];
    };

    const hasSalesModule = !!modules?.sales;
    const hasInvoicingModule = !!modules?.invoicing;
    %>

    <!-- Brand -->
    <a class="sidebar-brand d-flex align-items-center" style="justify-content: space-between;" href="/dashboard">
      <div class="sidebar-brand-icon">
        <img src="https://bitiray.com/public/assets/images/logos/invoicing-logo-white.png" style="width: 55%" alt="" />
      </div>
    </a>

    <hr class="sidebar-divider my-0" />

    <!-- Dashboard -->
    <% if (can('dashboard')) { %>
      <li class="nav-item <%= title === 'Dashboard' ? 'active' : '' %>">
        <a class="nav-link" href="/dashboard">
          <i class="fas fa-fw fa-tachometer-alt"></i>
          <span>Dashboard</span>
        </a>
      </li>
      <hr class="sidebar-divider" />
      <% } %>

        <!-- ===================== -->
        <!-- MÓDULO: VENDAS -->
        <!-- ===================== -->
        <% if (hasSalesModule && (can('sales') || can('stock') || can('products'))) { %>
          <div class="sidebar-heading">Vendas</div>

          <% if (can('sales')) { %>
            <li class="nav-item <%= ['Vendas','Nova Venda','Lista de Vendas'].includes(title) ? 'active' : '' %>">
              <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapseSales"
                aria-expanded="true" aria-controls="collapseSales">
                <i class="fa-solid fa-cart-shopping"></i>
                <span>Vendas</span>
              </a>
              <div id="collapseSales"
                class="collapse <%= ['Vendas','Nova Venda','Lista de Vendas'].includes(title) ? 'show' : '' %>"
                aria-labelledby="headingSales" data-parent="#accordionSidebar">
                <div class="bg-white py-2 collapse-inner rounded">
                  <h6 class="collapse-header">Opções:</h6>
                  <a class="collapse-item <%= title === 'Nova Venda' ? 'active' : '' %>" href="/new-sale">Nova venda</a>
                  <a class="collapse-item <%= ['Vendas','Lista de Vendas'].includes(title) ? 'active' : '' %>"
                    href="/sales">Lista de vendas</a>
                </div>
              </div>
            </li>
            <% } %>

              <% if (can('stock') || can('products')) { %>
                <li class="nav-item <%= ['Stocks','Movimentos de Stock','Produtos'].includes(title) ? 'active' : '' %>">
                  <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapseStocks"
                    aria-expanded="true" aria-controls="collapseStocks">
                    <i class="fa-solid fa-boxes-stacked"></i>
                    <span>Stock</span>
                  </a>
                  <div id="collapseStocks"
                    class="collapse <%= ['Stocks','Movimentos de Stock','Produtos'].includes(title) ? 'show' : '' %>"
                    aria-labelledby="headingStocks" data-parent="#accordionSidebar">
                    <div class="bg-white py-2 collapse-inner rounded">
                      <h6 class="collapse-header">Opções:</h6>

                      <% if (can('products')) { %>
                        <a class="collapse-item <%= title === 'Produtos' ? 'active' : '' %>"
                          href="/products">Produtos</a>
                        <% } %>

                          <% if (can('stock')) { %>
                            <a class="collapse-item <%= title === 'Movimentos de Stock' ? 'active' : '' %>"
                              href="/stock-movements">Movimentos de stock</a>
                            <% } %>
                    </div>
                  </div>
                </li>
                <% } %>

                  <hr class="sidebar-divider" />
                  <% } %>

                    <!-- ===================== -->
                    <!-- MÓDULO: FACTURAÇÃO -->
                    <!-- ===================== -->
                    <% if (hasInvoicingModule && (can('invoicing') || can('customers') || can('reports'))) { %>
                      <div class="sidebar-heading">Facturação</div>

                      <% if (can('invoicing')) { %>
                        <li
                          class="nav-item <%= ['Facturas', 'VD', 'Recibos', 'Cotações'].includes(title) ? 'active' : '' %>">
                          <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapseDocuments"
                            aria-expanded="true" aria-controls="collapseDocuments">
                            <i class="fa-solid fa-file-invoice-dollar"></i>
                            <span>Documentos</span>
                          </a>

                          <div id="collapseDocuments"
                            class="collapse <%= ['Facturas', 'VD', 'Recibos', 'Cotações'].includes(title) ? 'show' : '' %>"
                            aria-labelledby="headingDocuments" data-parent="#accordionSidebar">
                            <div class="bg-white py-2 collapse-inner rounded">
                              <h6 class="collapse-header">Opções:</h6>

                              <a class="collapse-item <%= title === 'Facturas' ? 'active' : '' %>" href="/invoices">
                                Facturas
                              </a>

                              <a class="collapse-item <%= title === 'VD' ? 'active' : '' %>" href="/vd">
                                VD
                              </a>

                              <a class="collapse-item <%= title === 'Recibos' ? 'active' : '' %>" href="/receipts">
                                Recibos
                              </a>

                              <a class="collapse-item <%= title === 'Cotações' ? 'active' : '' %>" href="/quotations">
                                Cotações
                              </a>
                            </div>
                          </div>
                        </li>
                        <% } %>

                          <% if (can('customers')) { %>
                            <li class="nav-item <%= title === 'Clientes' ? 'active' : '' %>">
                              <a class="nav-link" href="/clients">
                                <i class="fa-solid fa-users"></i>
                                <span>Clientes</span>
                              </a>
                            </li>
                            <% } %>

                              <% if (can('reports')) { %>
                                <li class="nav-item <%= title === 'Relatórios' ? 'active' : '' %>">
                                  <a class="nav-link" href="/reports">
                                    <i class="fa fa-file-excel"></i>
                                    <span>Relatórios</span>
                                  </a>
                                </li>
                                <% } %>

                                  <hr class="sidebar-divider" />
                                  <% } %>

                                    <% if (!hasSalesModule && !hasInvoicingModule) { %>
                                      <div class="sidebar-heading">Aviso</div>
                                      <li class="nav-item">
                                        <a class="nav-link" href="/settings">
                                          <i class="fa-solid fa-circle-exclamation"></i>
                                          <span>Ativar módulos</span>
                                        </a>
                                      </li>
                                      <% } %>

                                        <!-- ===================== -->
                                        <!-- UTILIZADORES -->
                                        <!-- ===================== -->
                                        <% if (can('users')) { %>
                                          <div class="sidebar-heading">Administração</div>

                                          <li class="nav-item <%= title === 'Utilizadores' ? 'active' : '' %>">
                                            <a class="nav-link" href="/users">
                                              <i class="fa-solid fa-users-gear"></i>
                                              <span>Utilizadores</span>
                                            </a>
                                          </li>

                                          <hr class="sidebar-divider" />
                                          <% } %>

                                            <!-- ===================== -->
                                            <!-- GLOBAL -->
                                            <!-- ===================== -->
                                            <div class="sidebar-heading">Conta</div>

                                            <% if (can('settings')) { %>
                                              <li class="nav-item <%= title === 'Configurações' ? 'active' : '' %>">
                                                <a class="nav-link" href="/settings">
                                                  <i class="fa-solid fa-cog"></i>
                                                  <span>Configurações</span>
                                                </a>
                                              </li>
                                              <% } %>

                                              <!-- Subscrição -->
                                              <li class="nav-item <%= ['A minha Subscrição', 'Upgrade de Plano'].includes(title) ? 'active' : '' %>">
                                                <a class="nav-link" href="/subscription">
                                                  <i class="fa-solid fa-star"></i>
                                                  <span>Subscrição</span>
                                                  <span id="sidebarPlanBadge" class="badge badge-pill ml-1" style="font-size:.65rem; display:none;"></span>
                                                </a>
                                              </li>

                                                <hr class="sidebar-divider" />

                                                <li class="nav-item">
                                                  <a class="nav-link btn_logout" href="#" onclick="logout()">
                                                    <i class="fa-solid fa-right-from-bracket fa-rotate-180"></i>
                                                    <span>Sair</span>
                                                  </a>
                                                </li>

                                                <hr class="sidebar-divider d-none d-md-block" />

                                                <div class="text-center d-none d-md-inline">
                                                  <button class="rounded-circle border-0" id="sidebarToggle"></button>
                                                </div>
</ul>
<!-- End of Sidebar -->

<script>
  // ── Ocultar sidebar imediatamente no mobile (evita flash) ──────────────────
  (function() {
    if (window.innerWidth < 768) {
      var s = document.getElementById('accordionSidebar');
      if (s) s.classList.add('toggled');
    }
  })();

  // ── Badge do plano na sidebar ──────────────────────────────────────────────
  (function() {
    var badge = document.getElementById('sidebarPlanBadge');
    if (!badge) return;
    fetch('/api/subscriptions/my')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.success) return;
        var s = data.subscription;
        badge.style.display = '';
        if (s.status === 'expired') {
          badge.textContent = 'Expirado';
          badge.className = 'badge badge-pill badge-danger ml-1';
        } else if (s.daysLeft <= 7) {
          badge.textContent = s.daysLeft + 'd';
          badge.className = 'badge badge-pill badge-warning ml-1';
        } else {
          badge.textContent = s.planLabel;
          badge.className = 'badge badge-pill badge-primary ml-1';
        }
      }).catch(function() {});
  })();

  // ── Mobile: backdrop + fechar ao clicar fora ───────────────────────────────
  document.addEventListener('DOMContentLoaded', function() {
    var sidebar = document.querySelector('.sidebar');

    function isMobile() { return window.innerWidth < 768; }

    // Criar backdrop
    var bd = document.createElement('div');
    bd.id = 'sidebarBackdrop';
    Object.assign(bd.style, {
      display: 'none',
      position: 'fixed',
      top: '0', left: '0', right: '0', bottom: '0',
      background: 'rgba(0,0,0,0.45)',
      zIndex: '1049',
      cursor: 'pointer'
    });
    document.body.appendChild(bd);

    function closeSidebar() {
      document.body.classList.add('sidebar-toggled');
      if (sidebar) {
        sidebar.classList.add('toggled');
        // Fechar submenus abertos
        sidebar.querySelectorAll('.collapse.show').forEach(function(el) {
          el.classList.remove('show');
        });
      }
      bd.style.display = 'none';
    }

    // Após clique no botão toggle, sincroniza o backdrop
    document.addEventListener('click', function(e) {
      if (!isMobile()) return;
      if (!e.target.closest('#sidebarToggleTop, #sidebarToggle')) return;
      setTimeout(function() {
        bd.style.display = (sidebar && !sidebar.classList.contains('toggled')) ? 'block' : 'none';
      }, 50);
    });

    // Redimensionamento
    window.addEventListener('resize', function() {
      if (isMobile()) {
        // Voltou ao mobile: garantir sidebar fechada se backdrop não estiver visível
        if (bd.style.display === 'none' && sidebar && !sidebar.classList.contains('toggled')) {
          sidebar.classList.add('toggled');
        }
      } else {
        // Desktop: remover toggled e esconder backdrop
        bd.style.display = 'none';
        if (sidebar) sidebar.classList.remove('toggled');
      }
    });

    // ── Flyout de submenus no mobile ───────────────────────────────────────────
    var flyout = document.createElement('div');
    flyout.id = 'sidebarFlyout';
    document.body.appendChild(flyout);

    var flyoutSource = null; // track which nav-link triggered the flyout

    function closeFlyout() {
      flyout.style.display = 'none';
      flyoutSource = null;
    }

    function openFlyout(trigger, collapseInnerEl) {
      // Clone the inner menu content
      flyout.innerHTML = collapseInnerEl.innerHTML;
      flyout.style.display = 'block';

      // Position: right of sidebar, vertically aligned with the trigger
      var sidebarRect = sidebar.getBoundingClientRect();
      var triggerRect = trigger.getBoundingClientRect();
      var flyoutH = flyout.offsetHeight;
      var viewH = window.innerHeight;

      var left = sidebarRect.right + 8;
      var top = triggerRect.top;

      // Clamp vertically so flyout stays within viewport
      if (top + flyoutH > viewH - 8) {
        top = viewH - flyoutH - 8;
      }
      if (top < 8) top = 8;

      flyout.style.left = left + 'px';
      flyout.style.top = top + 'px';
    }

    // Intercept submenu parent clicks on mobile
    sidebar.querySelectorAll('a[data-toggle="collapse"]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        if (!isMobile()) return; // desktop: let Bootstrap handle it normally
        e.preventDefault();
        e.stopPropagation();

        var targetId = link.getAttribute('data-target');
        var collapseEl = targetId ? document.querySelector(targetId) : null;
        var collapseInner = collapseEl ? collapseEl.querySelector('.collapse-inner') : null;
        if (!collapseInner) return;

        if (flyoutSource === link) {
          // Same item tapped again — close flyout
          closeFlyout();
        } else {
          flyoutSource = link;
          openFlyout(link, collapseInner);
        }
      });
    });

    // Close flyout when backdrop is clicked
    bd.addEventListener('click', function() {
      closeFlyout();
      closeSidebar();
    });

    // Close flyout when clicking anywhere outside sidebar+flyout
    document.addEventListener('click', function(e) {
      if (!isMobile()) return;
      if (flyout.style.display === 'none') return;
      if (flyout.contains(e.target)) return;
      if (sidebar.contains(e.target)) return;
      closeFlyout();
    });

    // Close flyout on resize to desktop
    window.addEventListener('resize', function() {
      if (!isMobile()) closeFlyout();
    });
  });
</script>