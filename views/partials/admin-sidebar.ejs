    </a>
  </li>

  <hr class="sidebar-divider"/>
  <div class="sidebar-heading">Gestão</div>

  <!-- Subscrições -->
  <li class="nav-item <%= title === 'Admin — Subscrições' ? 'active' : '' %>">
    <a class="nav-link" href="/admin/subscriptions">
      <i class="fas fa-fw fa-star"></i>
      <span>Subscrições</span>
      <span id="adminExpiringSoonBadge" class="badge badge-warning badge-pill ml-1" style="display:none;"></span>
