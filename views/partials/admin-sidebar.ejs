<script>
// Badge de subscrições a expirar
fetch('/api/admin/stats')
  .then(r => r.json())
  .then(data => {
    if (data.success && data.stats.expiringSoon > 0) {
      const b = document.getElementById('adminExpiringSoonBadge');
      b.textContent = data.stats.expiringSoon;
      b.style.display = '';
    }
  }).catch(() => {});

function logout() {
  fetch('/api/auth/logout', { method: 'POST' })
    .finally(() => { document.cookie = 'token=; Max-Age=0'; window.location.href = '/login'; });
}
</script>
