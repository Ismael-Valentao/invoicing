<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>
  <title>Invoicing - <%- title %></title>
  <link rel="icon" type="image/png" href="/images/invoicing-logo-simple.png"/>
  <link href="/assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css?family=Nunito:200,400,600,700,800" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous"/>
  <link href="/assets/css/sb-admin-2.min.css" rel="stylesheet"/>
  <link href="/assets/css/custom.css" rel="stylesheet"/>
</head>
<body id="page-top">
<div id="wrapper">
  <%- include('partials/sidebar') %>
  <div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
      <%- include('partials/topbar') %>
      <div class="container-fluid">
        <h5 class="mb-4 text-gray-800"><strong><i class="fas fa-chart-line mr-2 text-success"></i>Lucro por Produto</strong></h5>

        <div class="alert alert-info small mb-4">
          <i class="fas fa-info-circle mr-1"></i>
          Para ver o lucro correcto, defina o <strong>preço de custo</strong> de cada produto na página de Produtos.
          Produtos sem custo definido aparecem com margem de 100%.
        </div>

        <div class="card shadow mb-4">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover mb-0">
                <thead class="thead-light">
                  <tr>
                    <th>Produto</th>
                    <th class="text-center">Preço Venda</th>
                    <th class="text-center">Preço Custo</th>
                    <th class="text-center">Qtd Vendida</th>
                    <th class="text-center">Receita</th>
                    <th class="text-center">Custo Total</th>
                    <th class="text-center">Lucro</th>
                    <th class="text-center">Margem</th>
                  </tr>
                </thead>
                <tbody id="profitsTbody">
                  <tr><td colspan="8" class="text-center text-muted py-3">A carregar...</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    <%- include('partials/copyright') %>
  </div>
</div>
<%- include('partials/footer') %>
<script>
var cur = function(v) { return new Intl.NumberFormat('pt-MZ',{style:'currency',currency:'MZN'}).format(v||0); };

fetch('/api/features/product-profits').then(function(r){return r.json();}).then(function(data) {
  if (!data.success) return;
  var tbody = document.getElementById('profitsTbody');
  if (!data.products.length) {
    tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-3">Sem dados.</td></tr>';
    return;
  }
  tbody.innerHTML = data.products.map(function(p) {
    var marginColor = p.margin >= 50 ? 'success' : p.margin >= 20 ? 'warning' : 'danger';
    var profitColor = p.profit >= 0 ? 'success' : 'danger';
    return '<tr>'
      + '<td class="font-weight-bold">' + p.description + '</td>'
      + '<td class="text-center">' + cur(p.unitPrice) + '</td>'
      + '<td class="text-center">' + (p.costPrice > 0 ? cur(p.costPrice) : '<span class="text-muted">—</span>') + '</td>'
      + '<td class="text-center">' + p.soldQty + '</td>'
      + '<td class="text-center">' + cur(p.revenue) + '</td>'
      + '<td class="text-center">' + cur(p.cost) + '</td>'
      + '<td class="text-center font-weight-bold text-' + profitColor + '">' + cur(p.profit) + '</td>'
      + '<td class="text-center"><span class="badge badge-' + marginColor + '" style="font-size:.85rem;">' + p.margin + '%</span></td>'
      + '</tr>';
  }).join('');
}).catch(function(){});
</script>
</body>
</html>
